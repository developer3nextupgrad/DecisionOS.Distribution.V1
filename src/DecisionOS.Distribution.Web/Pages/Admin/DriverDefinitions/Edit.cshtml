@page
@model EditModel
@{
    ViewData["Title"] = "Edit Driver";
    Layout = "_Layout";
}

<div class="flex-1 w-full px-4 sm:px-6 md:px-8 py-10 flex justify-center">

    <div class="w-full max-w-[560px] space-y-8">

        <!-- HEADER -->
        <div class="flex items-center justify-between">
            <div class="flex items-center gap-3">
                <div class="w-10 h-10 bg-primary-container rounded-full flex items-center justify-center">
                    <span class="material-symbols-outlined text-on-primary-container">edit</span>
                </div>
                <div>
                    <h1 class="text-xl font-extrabold font-headline">Edit Driver</h1>
                    <p class="text-xs text-on-surface-variant">
                        Update driver definition
                    </p>
                </div>
            </div>

            <a href="/Admin/DriverDefinitions" class="p-2 hover:bg-surface-container-high rounded-full">
                <span class="material-symbols-outlined">close</span>
            </a>
        </div>

        <!-- FORM -->
        <div class="bg-surface-container-lowest rounded-2xl shadow p-8">

            <form method="post" class="space-y-10">

                <input type="hidden" asp-for="Id" />

                <div asp-validation-summary="ModelOnly" class="text-error text-sm"></div>

                <!-- IDENTIFIER -->
                <div>
                    <label class="text-[10px] font-bold uppercase text-on-surface-variant">Identifier</label>
                    <input value="@Model.Input.PillarCode / @Model.Input.DriverCode"
                           disabled
                           class="w-full mt-1 px-4 py-3 rounded-xl bg-surface-container-low font-mono" />
                </div>

                <!-- DISPLAY -->
                <div>
                    <label asp-for="Input.DisplayName" class="text-[10px] font-bold uppercase text-on-surface-variant"></label>
                    <input asp-for="Input.DisplayName"
                           class="w-full mt-1 px-4 py-3 rounded-xl bg-surface-container-low" />
                </div>

                <!-- DESC -->
                <div>
                    <label asp-for="Input.Description" class="text-[10px] font-bold uppercase text-on-surface-variant"></label>
                    <textarea asp-for="Input.Description"
                              class="w-full mt-1 px-4 py-3 rounded-xl bg-surface-container-low"></textarea>
                </div>

                <!-- ORDER -->
                <div>
                    <label asp-for="Input.SortOrder" class="text-[10px] font-bold uppercase text-on-surface-variant"></label>
                    <input asp-for="Input.SortOrder"
                           class="w-full mt-1 px-4 py-3 rounded-xl bg-surface-container-low" />
                </div>

                <!-- ACTIVE -->
                <label class="flex items-center gap-2 text-sm font-medium">
                    <input asp-for="Input.IsActive" />
                    Active
                </label>

                <!-- ACTIONS -->
                <div class="flex justify-end gap-4 pt-6 border-t">
                    <a href="/Admin/DriverDefinitions" class="px-6 py-2 text-sm">Cancel</a>
                    <button type="submit" class="px-8 py-2 bg-primary text-white rounded-xl font-bold">
                        Save Changes
                    </button>
                </div>

            </form>

        </div>

    </div>

</div>