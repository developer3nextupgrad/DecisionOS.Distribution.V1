@page
@model IndexModel
@{
    ViewData["Title"] = "KPI definitions & templates";
}
<h1 class="page-title">KPI definitions &amp; action templates</h1>
<p class="text-muted text-sm">
    Showing: <strong>@(Model.ProfileId is null ? "Global / default" : "Profile-scoped")</strong>.
    Use <a href="/Admin/Profiles">Business profiles</a> to navigate per profile.
</p>
<form method="get" class="card" style="margin-bottom:16px;">
    <div class="card-body">
        <div class="form-group">
            <label for="ProfileId">Business profile</label>
            <select id="ProfileId" name="ProfileId" class="form-control" asp-items="Model.ProfileOptions" onchange="this.form.submit()">
                <option value="">-- Global / default --</option>
            </select>
        </div>
    </div>
</form>
<div class="table-wrapper">
    <table class="data-table">
        <thead><tr><th>Code</th><th>Name</th><th>Unit</th><th>Priority</th><th></th></tr></thead>
        <tbody>
        @foreach (var k in Model.Items)
        {
            <tr>
                <td><code>@k.Code</code></td>
                <td>@k.Name</td>
                <td>@k.Unit</td>
                <td>@k.AlertPriority</td>
                <td><a href="/Admin/KpiDefinitions/Edit?id=@k.Id">Edit</a></td>
            </tr>
        }
        </tbody>
    </table>
</div>
<p class="text-sm"><a href="/Admin">&larr; Admin home</a></p>
