@page
@model DecisionOS.Distribution.Web.Pages.Admin.Profiles.EditModel
@{
    ViewData["Title"] = "Edit Business Profile";
    Layout = "_Layout";

    var currentPage = ViewContext.RouteData.Values["page"]?.ToString() ?? "";
}

    <!-- 🔥 MAIN -->
    <div class="flex-1 w-full flex justify-center px-4 sm:px-6 md:px-8 py-10">

        <div class="w-full max-w-[720px]">

            <!-- HEADER -->
            <div class="mb-8 flex justify-between items-end">
                <div>
                    <h1 class="text-2xl sm:text-3xl font-extrabold font-headline">Edit Business Profile</h1>
                    <p class="text-sm text-on-surface-variant mt-1">Update configuration and structure</p>
                </div>
            </div>

            <!-- CARD -->
            <div class="bg-surface-container-lowest rounded-2xl shadow p-6 sm:p-8">

                <form method="post" class="space-y-8">

                    <input type="hidden" asp-for="Id" />
                    <div asp-validation-summary="ModelOnly" class="text-error text-sm"></div>

                    <!-- BASIC -->
                    <div class="space-y-4">
                        <h2 class="text-xs font-bold uppercase text-on-surface-variant">Basic Info</h2>

                        <div class="grid grid-cols-1 md:grid-cols-3 gap-4">
                            <div>
                                <label class="text-xs font-bold">Code</label>
                                <input value="@Model.Input.Code" disabled
                                       class="w-full mt-1 px-4 py-2 rounded-xl bg-surface-container-low text-sm font-mono" />
                            </div>

                            <div class="md:col-span-2">
                                <label asp-for="Input.Name" class="text-xs font-bold"></label>
                                <input asp-for="Input.Name"
                                       class="w-full mt-1 px-4 py-2 rounded-xl bg-surface-container-low focus:ring-2 focus:ring-primary/20" />
                            </div>
                        </div>

                        <textarea asp-for="Input.Description"
                                  class="w-full px-4 py-2 rounded-xl bg-surface-container-low"></textarea>
                    </div>

                    <!-- CLASSIFICATION -->
                    <div class="space-y-4">
                        <h2 class="text-xs font-bold uppercase text-on-surface-variant">Classification</h2>

                        <select asp-for="Input.VerticalLibraryId"
                                asp-items="Model.VerticalOptions"
                                class="w-full px-4 py-2 rounded-xl bg-surface-container-low">
                            <option value="">Select Vertical</option>
                        </select>

                        <input asp-for="Input.LocationStructure" class="w-full px-4 py-2 rounded-xl bg-surface-container-low" />
                        <input asp-for="Input.ChannelStructure" class="w-full px-4 py-2 rounded-xl bg-surface-container-low" />
                    </div>

                    <!-- KPI -->
                    <div class="space-y-4">
                        <h2 class="text-xs font-bold uppercase text-on-surface-variant">KPI Config</h2>

                        <input asp-for="Input.ActiveKpiProfileCode" class="w-full px-4 py-2 rounded-xl bg-surface-container-low" />
                        <input asp-for="Input.ThresholdProfileCode" class="w-full px-4 py-2 rounded-xl bg-surface-container-low" />
                    </div>

                    <!-- ACTIVE -->
                    <div class="flex justify-between items-center bg-surface-container-low p-4 rounded-xl">
                        <span class="text-sm font-semibold">Active</span>
                        <input asp-for="Input.IsActive" type="checkbox" class="w-5 h-5 accent-primary" />
                    </div>

                    <!-- ACTION -->
                    <div class="flex justify-end gap-4 pt-4 border-t">

                        <a href="/Admin/Profiles"
                           class="px-4 py-2 text-sm text-on-surface-variant hover:bg-surface-container-high rounded-xl">
                            Cancel
                        </a>

                        <button type="submit"
                                class="px-6 py-2 bg-primary text-white rounded-xl font-bold">
                            Save Changes
                        </button>

                    </div>

                </form>

            </div>

        </div>

    </div>
