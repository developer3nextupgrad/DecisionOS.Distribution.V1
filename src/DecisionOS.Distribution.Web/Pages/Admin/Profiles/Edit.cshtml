@page
@model DecisionOS.Distribution.Web.Pages.Admin.Profiles.EditModel
@{
    ViewData["Title"] = "Edit profile";
}

<h1 class="page-title">Edit business profile</h1>
<form method="post" class="card" style="max-width:640px;">
    <input type="hidden" asp-for="Id" />
    <div class="card-body">
        <div asp-validation-summary="ModelOnly" class="text-danger"></div>
        <div class="form-group">
            <label>Code</label>
            <input class="form-control" value="@Model.Input.Code" disabled />
        </div>
        <div class="form-group">
            <label asp-for="Input.VerticalLibraryId">Vertical library</label>
            <select asp-for="Input.VerticalLibraryId" class="form-control" asp-items="Model.VerticalOptions">
                <option value="">-- Select a vertical --</option>
            </select>
        </div>
        <div class="form-group">
            <label asp-for="Input.Name"></label>
            <input asp-for="Input.Name" class="form-control" />
        </div>
        <div class="form-group">
            <label asp-for="Input.Description"></label>
            <textarea asp-for="Input.Description" class="form-control" rows="2"></textarea>
        </div>
        <div class="form-group">
            <label asp-for="Input.ActiveKpiProfileCode">Active KPI profile</label>
            <input asp-for="Input.ActiveKpiProfileCode" class="form-control" />
        </div>
        <div class="form-group">
            <label asp-for="Input.LocationStructure">Location structure</label>
            <input asp-for="Input.LocationStructure" class="form-control" />
        </div>
        <div class="form-group">
            <label asp-for="Input.ChannelStructure">Channel structure</label>
            <input asp-for="Input.ChannelStructure" class="form-control" />
        </div>
        <div class="form-group">
            <label asp-for="Input.ThresholdProfileCode">Threshold profile</label>
            <input asp-for="Input.ThresholdProfileCode" class="form-control" />
        </div>
        <div class="form-group">
            <label><input asp-for="Input.IsActive" /> Active</label>
        </div>
        <button type="submit" class="btn btn-primary">Save</button>
        <a href="/Admin/Profiles" class="btn btn-outline" style="margin-left:8px;">Cancel</a>
    </div>
</form>

