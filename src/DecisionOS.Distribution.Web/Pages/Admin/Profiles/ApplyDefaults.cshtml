@page
@model DecisionOS.Distribution.Web.Pages.Admin.Profiles.ApplyDefaultsModel
@{
    ViewData["Title"] = "Apply Defaults";
    Layout = "_Layout";

    var currentPage = ViewContext.RouteData.Values["page"]?.ToString() ?? "";
}

@if (Model.Profile is null)
{
    <div class="flex-1 w-full lg:ml-64 p-6">
        <p class="text-error font-semibold">Profile not found.</p>
    </div>
    return;
}

    <!-- 🔥 MAIN -->
    <div class="flex-1 w-full flex justify-center items-center px-4 sm:px-6 md:px-8 py-10">

        <div class="w-full max-w-[640px]">

            <div class="bg-surface-container-lowest rounded-2xl shadow overflow-hidden">

                <!-- HEADER -->
                <div class="px-8 pt-10 pb-6 border-b border-surface-container-high">
                    <h1 class="text-2xl font-extrabold font-headline mb-2">
                        Apply Defaults
                    </h1>
                    <p class="text-sm text-on-surface-variant">
                        Initialize profile with global KPI and driver templates
                    </p>
                </div>

                <!-- CONTENT -->
                <div class="p-8 space-y-6">

                    <!-- INFO -->
                    <div class="bg-surface-container-high p-6 rounded-xl flex gap-4">

                        <span class="material-symbols-outlined text-primary mt-1">info</span>

                        <div>
                            <p class="text-sm font-medium">
                                This will copy global KPI definitions and driver catalog into:
                            </p>

                            <div class="mt-2 inline-flex items-center px-3 py-1 bg-surface-container-low rounded-md">
                                <code class="text-xs font-bold">@Model.Profile.Code</code>
                            </div>
                        </div>
                    </div>

                    <!-- WARNING -->
                    <div class="bg-surface-container-low p-6 rounded-xl space-y-2">
                        <p class="text-sm font-semibold">Configuration Safeguards</p>

                        <ul class="text-sm text-on-surface-variant space-y-1">
                            <li>• Existing definitions will NOT be overwritten</li>
                            <li>• Only missing sections will be populated</li>
                        </ul>
                    </div>

                </div>

                <!-- ACTIONS -->
                <div class="px-8 py-6 bg-surface-container-low flex justify-end gap-4">

                    <a href="/Admin/Profiles"
                       class="px-5 py-2 rounded-xl text-sm text-on-surface-variant hover:bg-surface-container-high">
                        Cancel
                    </a>

                    <form method="post">
                        <input type="hidden" asp-for="Id" />

                        <button type="submit"
                                class="px-6 py-2 rounded-xl bg-primary text-white font-bold shadow hover:opacity-90">
                            Apply Defaults
                        </button>
                    </form>

                </div>

            </div>

            <!-- FOOT NOTE -->
            <p class="mt-6 text-center text-xs text-on-surface-variant">
                Changes will be logged for audit compliance.
            </p>

        </div>

    </div>
