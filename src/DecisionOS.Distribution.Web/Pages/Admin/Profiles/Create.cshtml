@page
@model DecisionOS.Distribution.Web.Pages.Admin.Profiles.CreateModel
@{
    ViewData["Title"] = "Add profile";
}

<h1 class="page-title">Add business profile</h1>
<form method="post" class="card" style="max-width:640px;">
    <div class="card-body">
        <div asp-validation-summary="ModelOnly" class="text-danger"></div>
        <div class="form-group">
            <label asp-for="Input.Code"></label>
            <input asp-for="Input.Code" class="form-control" />
            <span class="text-muted text-sm">Example: <code>BEER_DISTRIBUTOR</code></span>
            <span asp-validation-for="Input.Code" class="text-danger"></span>
        </div>
        <div class="form-group">
            <label asp-for="Input.Name"></label>
            <input asp-for="Input.Name" class="form-control" />
        </div>
        <div class="form-group">
            <label asp-for="Input.Description"></label>
            <textarea asp-for="Input.Description" class="form-control" rows="2"></textarea>
        </div>
        <div class="form-group">
            <label><input asp-for="Input.IsActive" /> Active</label>
        </div>
        <button type="submit" class="btn btn-primary">Save</button>
        <a href="/Admin/Profiles" class="btn btn-outline" style="margin-left:8px;">Cancel</a>
    </div>
</form>

