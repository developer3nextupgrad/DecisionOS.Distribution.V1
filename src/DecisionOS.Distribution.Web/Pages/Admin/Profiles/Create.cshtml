@page
@model DecisionOS.Distribution.Web.Pages.Admin.Profiles.CreateModel
@{
    ViewData["Title"] = "Add Business Profile";
    Layout = "_Layout";

    var currentPage = ViewContext.RouteData.Values["page"]?.ToString() ?? "";
}

<div class="flex">

    <!-- 🔥 SIDEBAR (SAME GLOBAL) -->
    <aside class="hidden lg:flex fixed top-0 left-0 h-screen w-64
                  bg-surface-container-highest border-r border-surface-container-high
                  flex-col px-4 py-6 z-40">

        <div class="mb-8 px-2">
            <h2 class="text-lg font-bold font-headline">Decision OS</h2>
            <p class="text-xs text-on-surface-variant">ADMIN</p>
        </div>

        @functions {
            string Active(string key, string current) =>
            current.Contains(key)
            ? "bg-surface-container-lowest shadow-sm font-semibold"
            : "text-on-surface-variant hover:bg-white";
        }

        <nav class="flex-1 space-y-1">

            <a href="/Admin/VerticalLibraries" class="flex items-center gap-3 px-4 py-3 rounded-xl @Active("VerticalLibraries", currentPage)">
                <span class="material-symbols-outlined">library_books</span>
                Vertical Libraries
            </a>

            <a href="/Admin/Profiles" class="flex items-center gap-3 px-4 py-3 rounded-xl @Active("Profiles", currentPage)">
                <span class="material-symbols-outlined">business_center</span>
                Business Profiles
            </a>

            <a href="/Admin/Tenants" class="flex items-center gap-3 px-4 py-3 rounded-xl @Active("Tenants", currentPage)">
                <span class="material-symbols-outlined">domain</span>
                Tenants
            </a>

            <a href="/Admin/KpiDefinitions" class="flex items-center gap-3 px-4 py-3 rounded-xl @Active("KpiDefinitions", currentPage)">
                <span class="material-symbols-outlined">leaderboard</span>
                KPI Definitions
            </a>

            <a href="/Admin/DriverDefinitions" class="flex items-center gap-3 px-4 py-3 rounded-xl @Active("DriverDefinitions", currentPage)">
                <span class="material-symbols-outlined">account_tree</span>
                Driver Catalog
            </a>

            <a href="/Admin/Influencers" class="flex items-center gap-3 px-4 py-3 rounded-xl @Active("Influencers", currentPage)">
                <span class="material-symbols-outlined">insights</span>
                Influencers
            </a>

            <a href="/Admin/Users" class="flex items-center gap-3 px-4 py-3 rounded-xl @Active("Users", currentPage)">
                <span class="material-symbols-outlined">group</span>
                Users & Roles
            </a>

            <div class="my-4 border-t border-surface-container-high"></div>

            <a href="/ImportHistory" class="flex items-center gap-3 px-4 py-3 rounded-xl @Active("ImportHistory", currentPage)">
                <span class="material-symbols-outlined">history</span>
                Import History
            </a>

        </nav>

        <div class="mt-auto px-2 pt-6">
            <a href="/Admin/Profiles/Create"
               class="w-full flex items-center justify-center gap-2 px-4 py-3
                      bg-primary text-white font-bold rounded-xl shadow">
                <span class="material-symbols-outlined text-sm">add</span>
                New Profile
            </a>
        </div>

    </aside>

    <!-- 🔥 MAIN -->
    <div class="flex-1 w-full lg:ml-64 flex justify-center px-4 sm:px-6 md:px-8 py-10">

        <div class="w-full max-w-[720px]">

            <!-- HEADER -->
            <div class="mb-10">
                <h1 class="text-2xl sm:text-3xl font-extrabold font-headline">
                    Add Business Profile
                </h1>
                <p class="text-sm text-on-surface-variant mt-1">
                    Define industry-specific KPI structure
                </p>
            </div>

            <!-- FORM CARD -->
            <div class="bg-surface-container-lowest rounded-2xl shadow p-6 sm:p-8">

                <form method="post" class="space-y-10">

                    <div asp-validation-summary="ModelOnly" class="text-error text-sm"></div>

                    <!-- BASIC -->
                    <div class="space-y-6">
                        <h2 class="text-xs font-bold uppercase text-on-surface-variant">Basic Info</h2>

                        <div class="grid grid-cols-1 md:grid-cols-2 gap-6">

                            <div>
                                <label asp-for="Input.Code" class="text-xs font-bold"></label>
                                <input asp-for="Input.Code"
                                       class="w-full mt-1 px-4 py-3 rounded-xl bg-surface-container-low font-mono text-sm focus:ring-2 focus:ring-primary/20" />
                                <p class="text-xs text-on-surface-variant mt-1">
                                    Example: <code>BEER_DISTRIBUTOR</code>
                                </p>
                                <span asp-validation-for="Input.Code" class="text-error text-xs"></span>
                            </div>

                            <div>
                                <label asp-for="Input.Name" class="text-xs font-bold"></label>
                                <input asp-for="Input.Name"
                                       class="w-full mt-1 px-4 py-3 rounded-xl bg-surface-container-low focus:ring-2 focus:ring-primary/20" />
                            </div>

                            <div class="md:col-span-2">
                                <label asp-for="Input.Description" class="text-xs font-bold"></label>
                                <textarea asp-for="Input.Description"
                                          class="w-full mt-1 px-4 py-3 rounded-xl bg-surface-container-low"></textarea>
                            </div>

                        </div>
                    </div>

                    <!-- CLASSIFICATION -->
                    <div class="space-y-6">
                        <h2 class="text-xs font-bold uppercase text-on-surface-variant">Classification</h2>

                        <select asp-for="Input.VerticalLibraryId"
                                asp-items="Model.VerticalOptions"
                                class="w-full px-4 py-3 rounded-xl bg-surface-container-low">
                            <option value="">Select Vertical</option>
                        </select>

                        <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                            <input asp-for="Input.LocationStructure"
                                   class="w-full px-4 py-3 rounded-xl bg-surface-container-low"
                                   placeholder="Location structure" />

                            <input asp-for="Input.ChannelStructure"
                                   class="w-full px-4 py-3 rounded-xl bg-surface-container-low"
                                   placeholder="Channel structure" />
                        </div>
                    </div>

                    <!-- KPI -->
                    <div class="space-y-6">
                        <h2 class="text-xs font-bold uppercase text-on-surface-variant">KPI Configuration</h2>

                        <input asp-for="Input.ActiveKpiProfileCode"
                               class="w-full px-4 py-3 rounded-xl bg-surface-container-low"
                               placeholder="Active KPI Profile" />

                        <p class="text-xs text-on-surface-variant">
                            Example: <code>PILOT_7</code>
                        </p>

                        <input asp-for="Input.ThresholdProfileCode"
                               class="w-full px-4 py-3 rounded-xl bg-surface-container-low"
                               placeholder="Threshold Profile" />
                    </div>

                    <!-- ACTIVE -->
                    <div class="flex justify-between items-center bg-surface-container-low p-4 rounded-xl">
                        <span class="text-sm font-semibold">Active</span>
                        <input asp-for="Input.IsActive" type="checkbox" class="w-5 h-5 accent-primary" />
                    </div>

                    <!-- ACTION -->
                    <div class="flex justify-end gap-4 pt-6 border-t">

                        <a href="/Admin/Profiles"
                           class="px-4 py-2 text-sm text-on-surface-variant hover:bg-surface-container-high rounded-xl">
                            Cancel
                        </a>

                        <button type="submit"
                                class="px-6 py-2 bg-primary text-white rounded-xl font-bold">
                            Create Profile
                        </button>

                    </div>

                </form>

            </div>

        </div>

    </div>

</div>