@page
@model CreateModel
@{
    ViewData["Title"] = "Add Tenant";
    Layout = "_Layout";

    var currentPage = ViewContext.RouteData.Values["page"]?.ToString() ?? "";
}

<div class="flex">

    <!-- 🔥 SAME GLOBAL SIDEBAR -->
    <aside class="hidden lg:flex fixed top-0 left-0 h-screen w-64
                  bg-surface-container-highest border-r border-surface-container-high
                  flex-col px-4 py-6 z-40">

        <div class="mb-8 px-2">
            <h2 class="text-lg font-bold font-headline">Decision OS</h2>
            <p class="text-xs text-on-surface-variant">ADMIN</p>
        </div>

        @functions {
            string Active(string key, string current) =>
            current.Contains(key)
            ? "bg-surface-container-lowest shadow-sm font-semibold"
            : "text-on-surface-variant hover:bg-white";
        }

        <nav class="flex-1 space-y-1">

            <a href="/Admin/VerticalLibraries" class="flex items-center gap-3 px-4 py-3 rounded-xl @Active("VerticalLibraries", currentPage)">
                <span class="material-symbols-outlined">library_books</span>
                Vertical Libraries
            </a>

            <a href="/Admin/Profiles" class="flex items-center gap-3 px-4 py-3 rounded-xl @Active("Profiles", currentPage)">
                <span class="material-symbols-outlined">business_center</span>
                Business Profiles
            </a>

            <a href="/Admin/Tenants" class="flex items-center gap-3 px-4 py-3 rounded-xl @Active("Tenants", currentPage)">
                <span class="material-symbols-outlined">domain</span>
                Tenants
            </a>

            <a href="/Admin/KpiDefinitions" class="flex items-center gap-3 px-4 py-3 rounded-xl @Active("KpiDefinitions", currentPage)">
                <span class="material-symbols-outlined">leaderboard</span>
                KPI Definitions
            </a>

            <a href="/Admin/DriverDefinitions" class="flex items-center gap-3 px-4 py-3 rounded-xl @Active("DriverDefinitions", currentPage)">
                <span class="material-symbols-outlined">account_tree</span>
                Driver Catalog
            </a>

            <a href="/Admin/Influencers" class="flex items-center gap-3 px-4 py-3 rounded-xl @Active("Influencers", currentPage)">
                <span class="material-symbols-outlined">insights</span>
                Influencers
            </a>

            <a href="/Admin/Users" class="flex items-center gap-3 px-4 py-3 rounded-xl @Active("Users", currentPage)">
                <span class="material-symbols-outlined">group</span>
                Users & Roles
            </a>

            <div class="my-4 border-t border-surface-container-high"></div>

            <a href="/ImportHistory" class="flex items-center gap-3 px-4 py-3 rounded-xl @Active("ImportHistory", currentPage)">
                <span class="material-symbols-outlined">history</span>
                Import History
            </a>

        </nav>
    </aside>

    <!-- 🔥 MAIN -->
    <div class="flex-1 w-full lg:ml-64 px-4 sm:px-6 md:px-8 py-12 flex justify-center">

        <div class="w-full max-w-[560px]">

            <!-- HEADER -->
            <div class="mb-6">
                <h1 class="text-2xl font-extrabold font-headline">Create New Tenant</h1>
                <p class="text-sm text-on-surface-variant">
                    Onboard a new organization into the system
                </p>
            </div>

            <!-- FORM CARD -->
            <div class="bg-surface-container-lowest rounded-2xl shadow p-8">

                <form method="post" class="space-y-10">

                    <div asp-validation-summary="ModelOnly" class="text-error text-sm"></div>

                    <!-- 🔹 BASIC INFO -->
                    <section class="space-y-6">

                        <div class="flex items-center gap-2">
                            <span class="material-symbols-outlined text-primary text-sm">info</span>
                            <h2 class="text-[10px] font-bold uppercase tracking-widest text-on-surface-variant">
                                Basic Info
                            </h2>
                        </div>

                        <!-- CLIENT ID -->
                        <div>
                            <label asp-for="Input.ClientId" class="text-[10px] font-bold uppercase text-on-surface-variant"></label>
                            <input asp-for="Input.ClientId"
                                   placeholder="DEC-XXX-0000"
                                   class="w-full mt-1 px-4 py-3 rounded-xl bg-surface-container-low font-mono text-sm" />
                            <span asp-validation-for="Input.ClientId" class="text-error text-xs"></span>
                        </div>

                        <!-- NAME -->
                        <div>
                            <label asp-for="Input.Name" class="text-[10px] font-bold uppercase text-on-surface-variant"></label>
                            <input asp-for="Input.Name"
                                   class="w-full mt-1 px-4 py-3 rounded-xl bg-surface-container-low text-sm" />
                        </div>

                        <!-- ARCHETYPE -->
                        <div>
                            <label asp-for="Input.Archetype" class="text-[10px] font-bold uppercase text-on-surface-variant"></label>
                            <input asp-for="Input.Archetype"
                                   class="w-full mt-1 px-4 py-3 rounded-xl bg-surface-container-low text-sm" />
                        </div>

                    </section>

                    <!-- 🔹 CONFIG -->
                    <section class="space-y-6 pt-4 border-t">

                        <div class="flex items-center gap-2">
                            <span class="material-symbols-outlined text-primary text-sm">settings</span>
                            <h2 class="text-[10px] font-bold uppercase tracking-widest text-on-surface-variant">
                                Configuration
                            </h2>
                        </div>

                        <!-- PROFILE -->
                        <div>
                            <label asp-for="Input.BusinessProfileId" class="text-[10px] font-bold uppercase text-on-surface-variant"></label>
                            <select asp-for="Input.BusinessProfileId"
                                    asp-items="Model.ProfileOptions"
                                    class="w-full mt-1 px-4 py-3 rounded-xl bg-surface-container-low">
                                <option value="">-- Global / default --</option>
                            </select>

                            <p class="text-xs text-on-surface-variant mt-2">
                                Select an industry/business-type standard set for this tenant
                            </p>
                        </div>

                    </section>

                    <!-- 🔹 ACTIONS -->
                    <div class="flex justify-end gap-4 pt-6">

                        <a href="/Admin/Tenants"
                           class="px-6 py-2 text-sm font-semibold text-on-surface-variant hover:text-on-surface">
                            Cancel
                        </a>

                        <button type="submit"
                                class="px-10 py-2 bg-gradient-to-br from-primary to-primary-dim text-white font-bold rounded-xl shadow">
                            Create
                        </button>

                    </div>

                </form>

            </div>

        </div>

    </div>

</div>