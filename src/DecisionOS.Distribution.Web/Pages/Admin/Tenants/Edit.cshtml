@page
@model EditModel
@{
    ViewData["Title"] = "Edit tenant";
}
<h1 class="page-title">Edit tenant</h1>
<form method="post" class="card" style="max-width:560px;">
    <input type="hidden" asp-for="Id" />
    <div class="card-body">
        <div asp-validation-summary="ModelOnly" class="text-danger"></div>
        <div class="form-group">
            <label>Client ID</label>
            <input class="form-control" value="@Model.Input.ClientId" disabled />
            <input type="hidden" asp-for="Input.ClientId" />
        </div>
        <div class="form-group">
            <label asp-for="Input.Name"></label>
            <input asp-for="Input.Name" class="form-control" />
        </div>
        <div class="form-group">
            <label asp-for="Input.Archetype"></label>
            <input asp-for="Input.Archetype" class="form-control" />
        </div>
        <div class="form-group">
            <label asp-for="Input.BusinessProfileId">Business profile</label>
            <select asp-for="Input.BusinessProfileId" class="form-control" asp-items="Model.ProfileOptions">
                <option value="">-- Global / default --</option>
            </select>
        </div>
        <div class="form-group">
            <label>Overrides</label>
            <div class="text-muted text-sm" style="margin-bottom:6px;">
                Controlled tenant-specific adjustments (captured as data; avoid custom logic).
            </div>
            <a class="btn btn-outline" href="/Admin/Tenants/Overrides/Kpis?tenantId=@Model.Id">KPI overrides</a>
            <a class="btn btn-outline" style="margin-left:8px;" href="/Admin/Tenants/Overrides/Drivers?tenantId=@Model.Id">Driver overrides</a>
        </div>
        <button formaction="" type="submit" class="btn btn-primary">Save</button>
        <a href="/Admin/Tenants" class="btn btn-outline" style="margin-left:8px;">Cancel</a>
    </div>
</form>
