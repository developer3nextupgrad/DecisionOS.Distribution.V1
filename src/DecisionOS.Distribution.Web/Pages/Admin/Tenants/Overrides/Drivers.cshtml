@page
@model DecisionOS.Distribution.Web.Pages.Admin.Tenants.Overrides.DriversModel
@{
    ViewData["Title"] = "Driver Overrides";
    Layout = "_Layout";

    var currentPage = ViewContext.RouteData.Values["page"]?.ToString() ?? "";
}

@if (Model.Tenant is null)
{
    <div class="flex-1 w-full lg:ml-64 p-6">
        <p class="text-error font-semibold">Tenant not found.</p>
    </div>
    return;
}

<div class="flex">

    <!-- 🔥 SIDEBAR -->
    <aside class="hidden lg:flex fixed top-0 left-0 h-screen w-64
                  bg-surface-container-highest border-r border-surface-container-high
                  flex-col px-4 py-6 z-40">

        <div class="mb-8 px-2">
            <h2 class="text-lg font-bold font-headline">Decision OS</h2>
            <p class="text-xs text-on-surface-variant">ADMIN</p>
        </div>

        @functions {
            string Active(string key, string current) =>
            current.Contains(key)
            ? "bg-surface-container-lowest shadow-sm font-semibold"
            : "text-on-surface-variant hover:bg-white";
        }

        <nav class="flex-1 space-y-1">

            <a href="/Admin/VerticalLibraries" class="flex items-center gap-3 px-4 py-3 rounded-xl @Active("VerticalLibraries", currentPage)">
                <span class="material-symbols-outlined">library_books</span>
                Vertical Libraries
            </a>

            <a href="/Admin/Profiles" class="flex items-center gap-3 px-4 py-3 rounded-xl @Active("Profiles", currentPage)">
                <span class="material-symbols-outlined">business_center</span>
                Business Profiles
            </a>

            <a href="/Admin/Tenants" class="flex items-center gap-3 px-4 py-3 rounded-xl @Active("Tenants", currentPage)">
                <span class="material-symbols-outlined">domain</span>
                Tenants
            </a>

            <a href="/Admin/KpiDefinitions" class="flex items-center gap-3 px-4 py-3 rounded-xl @Active("KpiDefinitions", currentPage)">
                <span class="material-symbols-outlined">leaderboard</span>
                KPI Definitions
            </a>

            <a href="/Admin/DriverDefinitions" class="flex items-center gap-3 px-4 py-3 rounded-xl @Active("DriverDefinitions", currentPage)">
                <span class="material-symbols-outlined">account_tree</span>
                Driver Catalog
            </a>

            <a href="/Admin/Influencers" class="flex items-center gap-3 px-4 py-3 rounded-xl @Active("Influencers", currentPage)">
                <span class="material-symbols-outlined">insights</span>
                Influencers
            </a>

            <a href="/Admin/Users" class="flex items-center gap-3 px-4 py-3 rounded-xl @Active("Users", currentPage)">
                <span class="material-symbols-outlined">group</span>
                Users & Roles
            </a>

            <div class="my-4 border-t border-surface-container-high"></div>

            <a href="/ImportHistory" class="flex items-center gap-3 px-4 py-3 rounded-xl @Active("ImportHistory", currentPage)">
                <span class="material-symbols-outlined">history</span>
                Import History
            </a>

        </nav>
    </aside>

    <!-- 🔥 MAIN -->
    <div class="flex-1 w-full lg:ml-64 px-4 sm:px-6 md:px-8 py-10">

        <div class="max-w-[1200px] mx-auto space-y-8">

            <!-- HEADER -->
            <div class="flex flex-col md:flex-row justify-between items-start md:items-end gap-4">

                <div>
                    <h1 class="text-2xl sm:text-3xl font-extrabold font-headline">
                        Driver Overrides
                    </h1>

                    <p class="text-sm text-on-surface-variant mt-2">
                        Tenant: <strong>@Model.Tenant.Name</strong>
                        (<code>@Model.Tenant.ClientId</code>)
                        · Profile: <strong>@(Model.Tenant.BusinessProfile?.Name ?? "Global/default")</strong>
                    </p>
                </div>

                <a href="/Admin/Tenants/Overrides/DriversEdit?tenantId=@Model.TenantId"
                   class="flex items-center gap-2 px-5 py-3 bg-gradient-to-br from-primary to-primary-dim text-white font-bold rounded-xl shadow">
                    <span class="material-symbols-outlined">edit</span>
                    Edit Overrides
                </a>

            </div>

            <!-- INFO -->
            <p class="text-sm text-on-surface-variant">
                Effective values include global + profile + tenant override layers.
            </p>

            <!-- TABLE -->
            <div class="bg-surface-container-lowest rounded-2xl shadow overflow-hidden">

                <div class="overflow-x-auto">
                    <table class="w-full min-w-[900px] text-sm">

                        <thead class="bg-surface-container-high text-xs uppercase text-on-surface-variant">
                            <tr>
                                <th class="px-6 py-4 text-left">Pillar</th>
                                <th class="px-6 py-4 text-left">Driver Code</th>
                                <th class="px-6 py-4 text-left">Display Name</th>
                                <th class="px-6 py-4 text-left">Active</th>
                                <th class="px-6 py-4 text-left">Override</th>
                            </tr>
                        </thead>

                        <tbody>
                            @foreach (var r in Model.Rows)
                            {
                                var activeClass = r.EffectiveIsActive
                                ? "bg-primary/10 text-primary"
                                : "bg-surface-container-high text-on-surface-variant";

                                var overrideText = r.Override is null
                                ? "None"
                                : (r.Override.IsActive == false ? "Disabled" : "Active");

                                <tr class="border-b hover:bg-surface-container-low transition">

                                    <td class="px-6 py-4">
                                        <span class="px-3 py-1 rounded-full bg-surface-container text-xs font-bold">
                                            @r.PillarCode
                                        </span>
                                    </td>

                                    <td class="px-6 py-4 font-mono text-xs">
                                        @r.DriverCode
                                    </td>

                                    <td class="px-6 py-4 font-semibold">
                                        @r.DisplayName
                                    </td>

                                    <td class="px-6 py-4">
                                        <span class="px-3 py-1 rounded-full text-xs font-bold @activeClass">
                                            @(r.EffectiveIsActive ? "Yes" : "No")
                                        </span>
                                    </td>

                                    <td class="px-6 py-4">
                                        <span class="px-3 py-1 rounded-full text-xs font-bold">
                                            @overrideText
                                        </span>
                                    </td>

                                </tr>
                            }
                        </tbody>

                    </table>
                </div>

            </div>

            <!-- FOOT LINKS -->
            <div class="flex gap-4 text-sm text-on-surface-variant">
                <a href="/Admin/Tenants" class="hover:text-primary">← Tenants</a>
                <a href="/Admin" class="hover:text-primary">← Admin</a>
            </div>

        </div>

    </div>

</div>