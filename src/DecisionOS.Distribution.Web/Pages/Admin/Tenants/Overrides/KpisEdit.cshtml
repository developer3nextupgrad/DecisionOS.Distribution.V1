@page
@model DecisionOS.Distribution.Web.Pages.Admin.Tenants.Overrides.KpisEditModel
@{
    ViewData["Title"] = "Edit KPI override";
}

@if (Model.Tenant is null)
{
    <p>Tenant not found.</p>
    return;
}

<div class="page-header">
    <div>
        <h1 class="page-title">Edit KPI override</h1>
        <p class="text-muted text-sm" style="margin:0;">
            Tenant: <strong>@Model.Tenant.Name</strong> (<code>@Model.Tenant.ClientId</code>)
            &middot; Profile: <strong>@(Model.Tenant.BusinessProfile?.Name ?? "Global/default")</strong>
        </p>
    </div>
    <a class="btn btn-outline" href="/Admin/Tenants/Overrides/Kpis?tenantId=@Model.TenantId">Back</a>
</div>

<form method="post" class="card" style="max-width:760px;">
    <input type="hidden" asp-for="TenantId" />
    <div class="card-body">
        <div asp-validation-summary="ModelOnly" class="text-danger"></div>

        <div class="form-group">
            <label asp-for="Input.KpiCode">KPI code</label>
            <select asp-for="Input.KpiCode" class="form-control" asp-items="Model.KpiOptions" onchange="window.location='?tenantId=@Model.TenantId&kpiCode=' + encodeURIComponent(this.value)"></select>
        </div>

        <div class="form-group">
            <label class="checkbox">
                <input asp-for="Input.IsActive" />
                Active override
            </label>
            <div class="text-muted text-sm">If unchecked, the override stays in the DB but will not be applied.</div>
        </div>

        <div class="grid-2">
            <div class="form-group">
                <label asp-for="Input.Target"></label>
                <input asp-for="Input.Target" class="form-control" />
                <div class="text-muted text-sm">Leave blank to inherit from profile/global.</div>
            </div>
            <div class="form-group">
                <label asp-for="Input.AlertPriority"></label>
                <input asp-for="Input.AlertPriority" class="form-control" />
            </div>
            <div class="form-group">
                <label asp-for="Input.AmberThreshold"></label>
                <input asp-for="Input.AmberThreshold" class="form-control" />
            </div>
            <div class="form-group">
                <label asp-for="Input.RedThreshold"></label>
                <input asp-for="Input.RedThreshold" class="form-control" />
            </div>
            <div class="form-group">
                <label asp-for="Input.MinValue"></label>
                <input asp-for="Input.MinValue" class="form-control" />
            </div>
            <div class="form-group">
                <label asp-for="Input.MaxValue"></label>
                <input asp-for="Input.MaxValue" class="form-control" />
            </div>
        </div>

        <div class="form-group">
            <label asp-for="Input.RecommendedAction"></label>
            <textarea asp-for="Input.RecommendedAction" class="form-control" rows="3"></textarea>
        </div>
        <div class="form-group">
            <label asp-for="Input.DiagnosticChecks"></label>
            <textarea asp-for="Input.DiagnosticChecks" class="form-control" rows="3"></textarea>
        </div>

        <button type="submit" class="btn btn-primary">Save override</button>
        <button type="submit" name="action" value="delete" class="btn btn-outline" style="margin-left:8px;">Delete override</button>
    </div>
</form>

