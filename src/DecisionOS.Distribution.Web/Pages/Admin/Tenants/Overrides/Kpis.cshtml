@page
@model DecisionOS.Distribution.Web.Pages.Admin.Tenants.Overrides.KpisModel
@{
    ViewData["Title"] = "KPI Overrides";
    Layout = "_Layout";

    var currentPage = ViewContext.RouteData.Values["page"]?.ToString() ?? "";
}

@if (Model.Tenant is null)
{
    <div class="flex-1 w-full lg:ml-64 p-6">
        <p class="text-error font-semibold">Tenant not found.</p>
    </div>
    return;
}

    <!-- 🔥 MAIN -->
    <div class="flex-1 w-full px-4 sm:px-6 md:px-8 py-10 space-y-8">

        <div class="max-w-[1200px] mx-auto space-y-8">

            <!-- HEADER -->
            <div class="flex flex-col md:flex-row justify-between items-start md:items-center gap-4">

                <div>
                    <h1 class="text-2xl sm:text-3xl font-extrabold font-headline">
                        KPI Overrides
                    </h1>

                    <p class="text-sm text-on-surface-variant mt-2">
                        Tenant: <strong>@Model.Tenant.Name</strong>
                        (<code>@Model.Tenant.ClientId</code>)
                        · Profile: <strong>@(Model.Tenant.BusinessProfile?.Name ?? "Global/default")</strong>
                    </p>
                </div>

                <a href="/Admin/Tenants/Overrides/KpisEdit?tenantId=@Model.TenantId"
                   class="flex items-center gap-2 px-5 py-3 bg-primary text-white font-bold rounded-xl shadow">
                    <span class="material-symbols-outlined">edit</span>
                    Edit Overrides
                </a>

            </div>

            <!-- STATS -->
            <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-4">

                <div class="p-5 bg-surface-container-lowest rounded-xl shadow">
                    <p class="text-xs text-on-surface-variant">Total KPIs</p>
                    <p class="text-2xl font-extrabold">@(Model.Rows?.Count ?? 0)</p>
                </div>

                <div class="p-5 bg-surface-container-lowest rounded-xl shadow">
                    <p class="text-xs text-on-surface-variant">Overrides</p>
                    <p class="text-2xl font-extrabold">
                        @(Model.Rows?.Count(r => r.Override != null) ?? 0)
                    </p>
                </div>

                <div class="p-5 bg-surface-container-lowest rounded-xl shadow">
                    <p class="text-xs text-on-surface-variant">Disabled</p>
                    <p class="text-2xl font-extrabold">
                        @(Model.Rows?.Count(r => r.Override?.IsActive == false) ?? 0)
                    </p>
                </div>

                <div class="p-5 bg-surface-container-lowest rounded-xl shadow">
                    <p class="text-xs text-on-surface-variant">Active</p>
                    <p class="text-2xl font-extrabold">
                        @(Model.Rows?.Count(r => r.Override?.IsActive == true) ?? 0)
                    </p>
                </div>

            </div>

            <!-- TABLE -->
            <div class="bg-surface-container-lowest rounded-xl shadow overflow-hidden">

                <div class="overflow-x-auto">
                    <table class="w-full min-w-[1000px] text-sm">

                        <thead class="bg-surface-container-high text-xs uppercase text-on-surface-variant">
                            <tr>
                                <th class="px-6 py-4 text-left">KPI</th>
                                <th class="px-6 py-4 text-right">Target</th>
                                <th class="px-6 py-4 text-right">Amber</th>
                                <th class="px-6 py-4 text-right">Red</th>
                                <th class="px-6 py-4 text-right">Min</th>
                                <th class="px-6 py-4 text-right">Max</th>
                                <th class="px-6 py-4 text-center">Priority</th>
                                <th class="px-6 py-4 text-center">Override</th>
                            </tr>
                        </thead>

                        <tbody class="divide-y">

                            @foreach (var r in Model.Rows)
                            {
                                var overrideText = r.Override is null
                                ? "No"
                                : (r.Override.IsActive ? "Yes" : "Disabled");

                                <tr class="hover:bg-surface-container-low transition">

                                    <td class="px-6 py-4">
                                        <div class="flex flex-col">
                                            <code class="text-primary font-mono text-xs">@r.KpiCode</code>
                                            <span class="text-xs text-on-surface-variant">@r.KpiName</span>
                                        </div>
                                    </td>

                                    <td class="px-6 py-4 text-right font-mono">@r.Effective.Target</td>
                                    <td class="px-6 py-4 text-right font-mono">@r.Effective.AmberThreshold</td>
                                    <td class="px-6 py-4 text-right font-mono">@r.Effective.RedThreshold</td>
                                    <td class="px-6 py-4 text-right font-mono">@((r.Effective.MinValue?.ToString()) ?? "—")</td>
                                    <td class="px-6 py-4 text-right font-mono">@((r.Effective.MaxValue?.ToString()) ?? "—")</td>

                                    <td class="px-6 py-4 text-center">
                                        <span class="px-2 py-1 text-xs rounded bg-surface-container-high">
                                            @r.Effective.AlertPriority
                                        </span>
                                    </td>

                                    <td class="px-6 py-4 text-center">
                                        <span class="px-3 py-1 text-xs rounded-full
                                                @(overrideText == "Yes" ? "bg-primary/10 text-primary" :
                                                                                            overrideText == "Disabled" ? "bg-error/10 text-error" :
                                                                                            "bg-surface-container-high text-on-surface-variant")">
                                        @overrideText
                                    </span>
                                </td>

                                </tr>
                                                        }

                        </tbody>

                    </table>
                </div>

            </div>

            <!-- FOOT LINKS -->
            <div class="flex gap-4 text-sm text-on-surface-variant">
                <a href="/Admin/Tenants" class="hover:text-primary">← Tenants</a>
                <a href="/Admin" class="hover:text-primary">← Admin</a>
            </div>

        </div>

    </div>
