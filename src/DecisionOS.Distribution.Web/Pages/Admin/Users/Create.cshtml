@page
@model CreateModel
@{
    ViewData["Title"] = "Add user";
}
<h1 class="page-title">Add user</h1>
<form method="post" class="card" style="max-width:560px;">
    <div class="card-body">
        <div asp-validation-summary="All" class="text-danger"></div>
        <div class="form-group">
            <label asp-for="Input.Email"></label>
            <input asp-for="Input.Email" class="form-control" autocomplete="off" />
        </div>
        <div class="form-group">
            <label asp-for="Input.Password"></label>
            <input asp-for="Input.Password" class="form-control" autocomplete="new-password" />
        </div>
        <div class="form-group">
            <label asp-for="Input.DisplayName"></label>
            <input asp-for="Input.DisplayName" class="form-control" />
        </div>
        <fieldset class="form-group">
            <legend class="text-sm" style="font-weight:600;">Roles</legend>
            @foreach (var r in AppRoles.All)
            {
                var on = Model.SelectedRoles.Contains(r);
                <label style="display:block;">
                    <input type="checkbox" name="SelectedRoles" value="@r" checked="@on" />
                    @r
                </label>
            }
        </fieldset>
        <button type="submit" class="btn btn-primary">Create</button>
        <a href="/Admin/Users" class="btn btn-outline" style="margin-left:8px;">Cancel</a>
    </div>
</form>
