@page
@model DecisionOS.Distribution.Web.Pages.Admin.Influencers.EditModel
@{
    ViewData["Title"] = "Edit influencer";
    Layout = "_Layout";
}

<div class="px-6 md:px-10 py-10 flex justify-center">

    <div class="w-full max-w-[720px] bg-surface-container-lowest rounded-2xl p-8 shadow border border-outline/10 space-y-10">

        <!-- HEADER -->
        <div>
            <h2 class="text-2xl font-extrabold text-on-surface tracking-tight">
                Edit Influencer
            </h2>
            <p class="text-on-surface-variant text-sm">
                Update influence behavior and configuration.
            </p>
        </div>

        <form method="post" class="space-y-10">

            <input type="hidden" asp-for="Id" />

            <div asp-validation-summary="ModelOnly" class="text-error text-sm"></div>

            <!-- 🔹 IDENTIFIER (LOCKED) -->
            <section class="space-y-4">

                <label class="text-[10px] font-extrabold uppercase tracking-[0.15em] text-on-surface-variant flex items-center gap-2">
                    System Identifier
                    <span class="material-symbols-outlined text-[12px] opacity-50">lock</span>
                </label>

                <div class="bg-surface-container-low rounded-xl p-4 border border-outline/10">
                    <div class="text-[11px] font-bold text-on-surface-variant/70">
                        Pillar / Driver / Influencer Code
                    </div>

                    <div class="font-mono text-sm font-semibold text-on-surface mt-1">
                        @Model.Input.PillarCode / @Model.Input.DriverCode / @Model.Input.InfluencerCode
                    </div>
                </div>

            </section>

            <!-- 🔹 DETAILS -->
            <section class="space-y-6 pt-2 border-t border-surface-container-high">

                <div class="space-y-2">
                    <label asp-for="Input.DisplayName"
                           class="text-[10px] font-extrabold uppercase tracking-[0.15em] text-on-surface-variant"></label>

                    <input asp-for="Input.DisplayName"
                           class="w-full bg-surface-container-low rounded-xl px-4 py-3 text-sm focus:ring-2 focus:ring-primary/20" />

                    <span asp-validation-for="Input.DisplayName" class="text-error text-xs"></span>
                </div>

                <div class="space-y-2">
                    <label asp-for="Input.Description"
                           class="text-[10px] font-extrabold uppercase tracking-[0.15em] text-on-surface-variant"></label>

                    <textarea asp-for="Input.Description"
                              rows="4"
                              class="w-full bg-surface-container-low rounded-xl px-4 py-3 text-sm focus:ring-2 focus:ring-primary/20"></textarea>

                    <span asp-validation-for="Input.Description" class="text-error text-xs"></span>
                </div>

            </section>

            <!-- 🔹 IMPACT CONFIG -->
            <section class="space-y-6 pt-2 border-t border-surface-container-high">

                <div class="grid grid-cols-1 md:grid-cols-2 gap-8">

                    <!-- DIRECTION -->
                    <div class="space-y-2">
                        <label asp-for="Input.Direction"
                               class="text-[10px] font-extrabold uppercase tracking-[0.15em] text-on-surface-variant"></label>

                        <select asp-for="Input.Direction"
                                asp-items="Html.GetEnumSelectList<DecisionOS.Distribution.Domain.InfluencerImpactDirection>()"
                                class="w-full bg-surface-container-low rounded-xl px-4 py-3 text-sm focus:ring-2 focus:ring-primary/20">
                        </select>

                        <span asp-validation-for="Input.Direction" class="text-error text-xs"></span>
                    </div>

                    <!-- WEIGHT -->
                    <div class="space-y-2">
                        <label asp-for="Input.Weight"
                               class="text-[10px] font-extrabold uppercase tracking-[0.15em] text-on-surface-variant"></label>

                        <input asp-for="Input.Weight"
                               class="w-full bg-surface-container-low rounded-xl px-4 py-3 text-sm focus:ring-2 focus:ring-primary/20" />

                        <span asp-validation-for="Input.Weight" class="text-error text-xs"></span>
                    </div>

                </div>

            </section>

            <!-- 🔹 STATUS -->
            <section class="pt-2 border-t border-surface-container-high flex items-center justify-between">

                <div>
                    <h4 class="text-sm font-bold text-on-surface">
                        Active State
                    </h4>
                    <p class="text-xs text-on-surface-variant">
                        Toggle to enable or disable this influencer.
                    </p>
                </div>

                <label class="flex items-center gap-2">
                    <input asp-for="Input.IsActive" />
                    Active
                </label>

            </section>

            <!-- ACTIONS -->
            <div class="pt-6 flex justify-end gap-4 border-t border-outline/10">

                <a href="/Admin/Influencers?profileId=@Model.ProfileId"
                   class="px-6 py-2 text-sm font-semibold text-on-surface-variant hover:text-on-surface">
                    Cancel
                </a>

                <button type="submit"
                        class="px-8 py-2.5 bg-gradient-to-br from-primary to-primary-dim text-white rounded-xl font-bold shadow hover:scale-[1.02] transition">
                    Save Changes
                </button>

            </div>

        </form>

    </div>

</div>