@page
@model DecisionOS.Distribution.Web.Pages.Admin.VerticalLibraries.CreateModel
@{
    ViewData["Title"] = "Add Vertical Library";
    Layout = "_Layout";

    var currentPage = ViewContext.RouteData.Values["page"]?.ToString() ?? "";
}

<div class="flex">

    <!-- 🔥 SIDEBAR (EXACT SAME AS EDIT PAGE - FIXED) -->
    <aside class="hidden lg:flex fixed top-0 left-0 h-screen w-64
                  bg-surface-container-highest border-r border-surface-container-high
                  flex-col px-4 py-6 z-40">

        <div class="mb-8 px-2">
            <h2 class="text-lg font-bold font-headline">Decision OS</h2>
            <p class="text-xs text-on-surface-variant">ADMIN</p>
        </div>

        @functions {
            string Active(string key, string current) =>
            current.Contains(key)
            ? "bg-surface-container-lowest shadow-sm font-semibold"
            : "text-on-surface-variant hover:bg-white";
        }

        <nav class="flex-1 space-y-1">

            <a href="/Admin/VerticalLibraries" class="flex items-center gap-3 px-4 py-3 rounded-xl @Active("VerticalLibraries", currentPage)">
                <span class="material-symbols-outlined">library_books</span>
                Vertical Libraries
            </a>

            <a href="/Admin/BusinessProfiles" class="flex items-center gap-3 px-4 py-3 rounded-xl @Active("BusinessProfiles", currentPage)">
                <span class="material-symbols-outlined">business_center</span>
                Business Profiles
            </a>

            <a href="/Admin/Tenants" class="flex items-center gap-3 px-4 py-3 rounded-xl @Active("Tenants", currentPage)">
                <span class="material-symbols-outlined">domain</span>
                Tenants
            </a>

            <a href="/Admin/KpiDefinitions" class="flex items-center gap-3 px-4 py-3 rounded-xl @Active("KpiDefinitions", currentPage)">
                <span class="material-symbols-outlined">leaderboard</span>
                KPI Definitions
            </a>

            <a href="/Admin/DriverDefinitions" class="flex items-center gap-3 px-4 py-3 rounded-xl @Active("DriverDefinitions", currentPage)">
                <span class="material-symbols-outlined">account_tree</span>
                Driver Catalog
            </a>

            <a href="/Admin/Influencers" class="flex items-center gap-3 px-4 py-3 rounded-xl @Active("Influencers", currentPage)">
                <span class="material-symbols-outlined">insights</span>
                Influencers
            </a>

            <a href="/Admin/Users" class="flex items-center gap-3 px-4 py-3 rounded-xl @Active("Users", currentPage)">
                <span class="material-symbols-outlined">group</span>
                Users & Roles
            </a>

            <div class="my-4 border-t border-surface-container-high"></div>

            <a href="/ImportHistory" class="flex items-center gap-3 px-4 py-3 rounded-xl @Active("ImportHistory", currentPage)">
                <span class="material-symbols-outlined">history</span>
                Import History
            </a>

        </nav>

        <!-- BUTTON -->
        <div class="mt-auto px-2 pt-6">
            <a href="/Admin/VerticalLibraries/Create"
               class="w-full flex items-center justify-center gap-2 px-4 py-3
                      bg-primary text-white font-bold rounded-xl shadow">
                <span class="material-symbols-outlined text-sm">add</span>
                New Vertical
            </a>
        </div>

    </aside>

    <!-- 🔥 MAIN CONTENT -->
    <div class="flex-1 w-full lg:ml-64 flex items-center justify-center px-4 sm:px-6 md:px-8 py-8">

        <div class="w-full max-w-[640px] bg-surface-container-lowest rounded-2xl p-6 sm:p-10 shadow">

            <!-- HEADER -->
            <div class="mb-8">
                <h1 class="text-xl sm:text-2xl font-extrabold font-headline">
                    Add Vertical Library
                </h1>
                <p class="text-sm text-on-surface-variant mt-1">
                    Create a new business vertical category
                </p>
            </div>

            <!-- FORM -->
            <form method="post" class="space-y-6">

                <div asp-validation-summary="ModelOnly" class="text-error text-sm"></div>

                <!-- CODE + NAME -->
                <div class="grid grid-cols-1 md:grid-cols-3 gap-4">

                    <div>
                        <label asp-for="Input.Code" class="text-xs font-bold uppercase"></label>
                        <input asp-for="Input.Code"
                               class="w-full mt-1 px-4 py-3 rounded-xl bg-surface-container-low font-mono focus:ring-2 focus:ring-primary/20" />
                    </div>

                    <div class="md:col-span-2">
                        <label asp-for="Input.Name" class="text-xs font-bold uppercase"></label>
                        <input asp-for="Input.Name"
                               class="w-full mt-1 px-4 py-3 rounded-xl bg-surface-container-low focus:ring-2 focus:ring-primary/20" />
                    </div>

                </div>

                <!-- DESCRIPTION -->
                <div>
                    <label asp-for="Input.Description" class="text-xs font-bold uppercase"></label>
                    <textarea asp-for="Input.Description"
                              rows="3"
                              class="w-full mt-1 px-4 py-3 rounded-xl bg-surface-container-low focus:ring-2 focus:ring-primary/20"></textarea>
                </div>

                <!-- ACTIVE -->
                <div class="flex justify-between items-center bg-surface-container-low p-4 rounded-xl">

                    <div>
                        <p class="text-sm font-semibold">Active Status</p>
                        <p class="text-xs text-on-surface-variant">
                            Enable this vertical for new projects
                        </p>
                    </div>

                    <input asp-for="Input.IsActive"
                           type="checkbox"
                           class="w-5 h-5 accent-primary" />

                </div>

                <!-- ACTIONS -->
                <div class="flex justify-end gap-4 pt-4 border-t">

                    <a href="/Admin/VerticalLibraries"
                       class="px-4 py-2 text-sm rounded-xl text-on-surface-variant hover:bg-surface-container-high">
                        Cancel
                    </a>

                    <button type="submit"
                            class="px-6 py-2 bg-primary text-white font-bold rounded-xl shadow hover:opacity-90">
                        Create
                    </button>

                </div>

            </form>

        </div>

    </div>

</div>