@page
@model DecisionOS.Distribution.Web.Pages.Admin.VerticalLibraries.EditModel
@{
    ViewData["Title"] = "Edit Vertical Library";
    Layout = "_Layout";

    var currentPage = ViewContext.RouteData.Values["page"]?.ToString() ?? "";
}

    <!-- 🔥 MAIN CONTENT -->
    <div class="flex-1 w-full px-4 sm:px-6 md:px-8 py-8 flex justify-center">

        <!-- CARD -->
        <div class="w-full max-w-[640px] bg-surface-container-lowest rounded-[2rem] shadow p-6 sm:p-10">

            <h2 class="text-xl sm:text-2xl font-extrabold mb-2">Edit Vertical Library</h2>
            <p class="text-sm text-on-surface-variant mb-6">
                Update vertical details and status
            </p>

            <form method="post" class="space-y-6">

                <input type="hidden" asp-for="Id" />

                <div asp-validation-summary="ModelOnly" class="text-error text-sm"></div>

                <!-- CODE -->
                <div>
                    <label class="text-xs font-bold uppercase">Code</label>
                    <input value="@Model.Input.Code" disabled
                           class="w-full mt-1 px-4 py-3 rounded-xl bg-surface-container-low text-sm font-mono" />
                </div>

                <!-- NAME -->
                <div>
                    <label asp-for="Input.Name" class="text-xs font-bold uppercase"></label>
                    <input asp-for="Input.Name"
                           class="w-full mt-1 px-4 py-3 rounded-xl bg-surface-container-low focus:ring-2 focus:ring-primary/20" />
                </div>

                <!-- DESCRIPTION -->
                <div>
                    <label asp-for="Input.Description" class="text-xs font-bold uppercase"></label>
                    <textarea asp-for="Input.Description"
                              class="w-full mt-1 px-4 py-3 rounded-xl bg-surface-container-low focus:ring-2 focus:ring-primary/20"></textarea>
                </div>

                <!-- ACTIVE -->
                <div class="flex justify-between items-center bg-surface-container-low p-4 rounded-xl">
                    <span class="text-sm font-semibold">Active</span>
                    <input asp-for="Input.IsActive" type="checkbox" class="accent-primary w-5 h-5" />
                </div>

                <!-- ACTION -->
                <div class="flex justify-end gap-3 pt-4 border-t">

                    <a href="/Admin/VerticalLibraries"
                       class="px-4 py-2 rounded-xl text-sm hover:bg-surface-container-high">
                        Cancel
                    </a>

                    <button type="submit"
                            class="px-6 py-2 bg-primary text-white rounded-xl font-bold">
                        Save
                    </button>

                </div>

            </form>

        </div>

    </div>
