@page
@model DecisionOS.Distribution.Web.Pages.Admin.VerticalLibraries.IndexModel
@{
    ViewData["Title"] = "Vertical Libraries";
    Layout = "_Layout";

    var currentPage = ViewContext.RouteData.Values["page"]?.ToString() ?? "";
}

    <!-- 🔥 MAIN -->
    <div class="flex-1 p-4 sm:p-6 md:p-8 max-w-[1440px] mx-auto">

        <!-- HEADER -->
        <div class="flex flex-col sm:flex-row justify-between items-start sm:items-end gap-4 mb-8">
            <div>
                <h1 class="text-2xl sm:text-3xl font-extrabold font-headline">Vertical Libraries</h1>
                <p class="text-sm text-on-surface-variant mt-1">
                    Manage business vertical categories used by profiles
                </p>
            </div>

            <a href="/Admin/VerticalLibraries/Create"
               class="px-5 py-3 bg-gradient-to-br from-primary to-primary-dim text-white font-bold rounded-xl shadow hover:shadow-md transition flex items-center gap-2">
                <span class="material-symbols-outlined">add_circle</span>
                Add Vertical
            </a>
        </div>

        <!-- 🔥 STATS -->
        <section class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-4 sm:gap-6 mb-6">

            <div class="p-5 bg-surface-container-lowest rounded-xl shadow">
                <p class="text-xs font-bold text-primary uppercase">Total Categories</p>
                <p class="text-2xl font-bold mt-1">@Model.Items.Count</p>
            </div>

            <div class="p-5 bg-surface-container-lowest rounded-xl shadow">
                <p class="text-xs font-bold text-on-surface-variant uppercase">Active Status</p>
                <p class="text-2xl font-bold mt-1">
                    @Model.Items.Count(x => x.IsActive)
                </p>
            </div>

            <div class="col-span-1 sm:col-span-2 p-5 bg-primary/10 rounded-xl relative overflow-hidden">
                <p class="text-xs font-bold uppercase text-primary">System Health</p>
                <p class="text-lg font-bold mt-1 text-primary">
                    All Libraries Synced
                </p>
                <span class="material-symbols-outlined absolute right-2 bottom-2 text-6xl opacity-10">
                    sync
                </span>
            </div>

        </section>


        <!-- 🔥 FILTER BAR -->
        <div class="flex flex-col sm:flex-row justify-between gap-4 mb-6">

            <div class="flex flex-col sm:flex-row gap-3 sm:items-center">

                <!-- SEARCH -->
                <div class="relative">
                    <span class="material-symbols-outlined absolute left-3 top-1/2 -translate-y-1/2 text-on-surface-variant">
                        search
                    </span>
                    <input type="text"
                           placeholder="Search verticals..."
                           class="pl-10 pr-4 py-2 rounded-full bg-surface-container-low text-sm w-full sm:w-64 focus:ring-2 focus:ring-primary outline-none" />
                </div>

                <!-- FILTER BUTTONS -->
                <div class="flex bg-surface-container-low rounded-full p-1 text-sm">
                    <button class="px-3 py-1 rounded-full bg-white font-semibold">All</button>
                    <button class="px-3 py-1 text-on-surface-variant">Active</button>
                    <button class="px-3 py-1 text-on-surface-variant">Inactive</button>
                </div>

            </div>

            <!-- MORE FILTER -->
            <button class="flex items-center gap-2 text-sm text-on-surface-variant hover:text-primary">
                <span class="material-symbols-outlined">filter_list</span>
                More Filters
            </button>

        </div>

        <!-- TABLE -->
        <div class="bg-surface-container-lowest rounded-xl shadow border overflow-hidden">

            <div class="overflow-x-auto">
                <table class="w-full min-w-[700px] text-sm">

                    <thead class="bg-surface-container-high text-xs uppercase text-on-surface-variant">
                        <tr>
                            <th class="px-4 py-4 text-left">Code</th>
                            <th class="px-4 py-4 text-left">Name & Description</th>
                            <th class="px-4 py-4 text-left">Status</th>
                            <th class="px-4 py-4 text-right">Actions</th>
                        </tr>
                    </thead>

                    <tbody>
                        @foreach (var v in Model.Items)
                        {
                            var statusClass = v.IsActive
                            ? "bg-primary/10 text-primary"
                            : "bg-surface-container-high text-on-surface-variant";

                            <tr class="border-b hover:bg-surface-container-low transition">

                                <!-- CODE -->
                                <td class="px-4 py-4">
                                    <span class="font-mono text-xs px-2 py-1 bg-surface-container-high rounded">
                                        @v.Code
                                    </span>
                                </td>

                                <!-- NAME -->
                                <td class="px-4 py-4">
                                    <div>
                                        <p class="font-bold">@v.Name</p>
                                        <p class="text-xs text-on-surface-variant">@v.Description</p>
                                    </div>
                                </td>

                                <!-- STATUS -->
                                <td class="px-4 py-4">
                                    <span class="px-3 py-1 rounded-full text-xs font-bold @statusClass">
                                        @(v.IsActive ? "Active" : "Inactive")
                                    </span>
                                </td>

                                <!-- ACTION -->
                                <td class="px-4 py-4 text-right">
                                    <a href="/Admin/VerticalLibraries/Edit?id=@v.Id"
                                       class="text-primary font-semibold text-sm hover:underline">
                                        Edit
                                    </a>
                                </td>

                            </tr>
                        }
                    </tbody>

                </table>
            </div>

        </div>

        <!-- FOOTER LINK -->
        <div class="mt-6">
            <a href="/Admin" class="text-sm text-on-surface-variant hover:text-primary flex items-center gap-2">
                <span class="material-symbols-outlined text-base">arrow_back</span>
                Admin home
            </a>
        </div>

    </div>

