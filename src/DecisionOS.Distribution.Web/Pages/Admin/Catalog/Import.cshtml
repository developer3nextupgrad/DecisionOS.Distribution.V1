@page
@model ImportModel
@{
    ViewData["Title"] = "Import Catalog";
    Layout = "_IndexLayout";
}

<div class="flex-1 w-full px-4 sm:px-6 md:px-8 py-6 max-w-3xl mx-auto">
    <h1 class="text-2xl font-extrabold font-headline mb-2">Import catalog workbook</h1>
    <p class="text-sm text-on-surface-variant mb-6">
        Upload <code>DPOS_Distribution_KPI_Driver_Influencer_Developer_Catalog_v1.0.xlsx</code>.
        Import is idempotent (upserts by stable IDs).
    </p>

    @if (!string.IsNullOrEmpty(Model.ErrorMessage))
    {
        <div class="mb-4 p-4 rounded-xl bg-red-50 text-red-800 text-sm">@Model.ErrorMessage</div>
    }

    <form method="post" enctype="multipart/form-data" class="space-y-4 bg-surface-container-lowest p-6 rounded-xl border">
        <div>
            <label class="text-xs font-bold uppercase text-on-surface-variant">Workbook file</label>
            <input type="file" name="Upload" accept=".xlsx" class="block w-full mt-2 text-sm" required />
        </div>
        <button type="submit" class="px-4 py-2 rounded-xl bg-primary text-on-primary text-sm font-semibold">
            Import
        </button>
    </form>

    @if (Model.Result is not null)
    {
        <div class="mt-8 p-6 rounded-xl border bg-surface-container-lowest">
            <h2 class="font-bold mb-4">Import summary</h2>
            <ul class="text-sm space-y-1">
                <li>KPIs: @Model.Result.KpisImported</li>
                <li>Drivers: @Model.Result.DriversImported</li>
                <li>Influencers: @Model.Result.InfluencersImported</li>
                <li>KPI→Driver maps: @Model.Result.KpiDriverMapsImported</li>
                <li>Driver→Influencer maps: @Model.Result.DriverInfluencerMapsImported</li>
                <li>Score components: @Model.Result.ScoreComponentsImported</li>
                <li>Modules: @Model.Result.ModulesImported</li>
                <li>Output areas: @Model.Result.OutputAreasImported</li>
            </ul>
            @if (Model.Result.Errors.Count > 0)
            {
                <div class="mt-4 text-sm text-amber-800">
                    <strong>Warnings:</strong>
                    <ul class="list-disc ml-5 mt-1">
                        @foreach (var err in Model.Result.Errors)
                        {
                            <li>@err</li>
                        }
                    </ul>
                </div>
            }
            <a href="/Admin/Catalog" class="inline-block mt-4 text-primary text-sm font-semibold">View catalog summary →</a>
        </div>
    }
</div>
