@page
@model DecisionOS.Distribution.Web.Pages.Admin.ExcelMapper.IndexModel
@{
    ViewData["Title"] = "Excel Mapper";
    Layout = "_Layout";
}

<div class="max-w-[900px] mx-auto space-y-8">
    <div>
        <h1 class="text-3xl font-headline font-bold">Excel Mapper</h1>
        <p class="text-sm text-on-surface-variant mt-1">
            Turn a distributor’s Excel file into a DecisionOS-ready workbook you can upload with Simplified import.
        </p>
    </div>

    @if (!string.IsNullOrWhiteSpace(Model.Error))
    {
        <div class="p-3 rounded-lg bg-error/10 text-error text-sm font-semibold">@Model.Error</div>
    }

    <div class="rounded-xl border border-surface-container-high bg-surface-container-lowest p-5 space-y-3">
        <div class="text-sm font-semibold">How it works (4 steps)</div>
        <ol class="text-sm text-on-surface-variant list-decimal pl-5 space-y-2">
            <li><strong>Upload</strong> the Excel file you received from the distributor (multi-tab .xlsx).</li>
            <li><strong>Check each tab</strong> — confirm whether it is Weekly financials, Sales, AR, AP, Inventory, or Skip.</li>
            <li><strong>Fix columns if needed</strong> — match their column names to DecisionOS fields, then Save.</li>
            <li><strong>Download</strong> the mapped file, then go to <strong>Operations → Uploads → Simplified</strong> and upload it.</li>
        </ol>
        <p class="text-xs text-on-surface-variant">
            If a tab shows “We’re unsure…”, choose the correct Role and Save — that clears the warning.
        </p>
        <a href="/downloads/DecisionOS_Simplified_Workbook_Template.xlsx"
           download="DecisionOS_Simplified_Workbook_Template.xlsx"
           class="inline-flex items-center gap-2 px-4 py-2 rounded-lg border border-primary text-primary text-sm font-bold hover:bg-primary/5">
            Download reference template (.xlsx)
        </a>
    </div>

    <form method="post" asp-page-handler="Upload" enctype="multipart/form-data"
          class="bg-surface-container-lowest border border-surface-container-high rounded-xl p-6 space-y-4">
        @Html.AntiForgeryToken()
        <div>
            <label class="block text-sm font-semibold mb-2">Distributor Excel workbook</label>
            <input type="file" name="WorkbookFile" accept=".xlsx,.xls" class="w-full" />
            <p class="text-xs text-on-surface-variant mt-1">
                Prefer .xlsx. Notes or README tabs can be marked Skip on the next screen.
            </p>
        </div>
        <button type="submit" class="bg-primary text-white px-6 py-2 rounded-xl font-bold">Analyze workbook</button>
    </form>
</div>
