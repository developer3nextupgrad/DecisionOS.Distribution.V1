@page
@model IndexModel
@{
    ViewData["Title"] = "Setup Context";
    Layout = "_IndexLayout";
}

<div class="flex items-center justify-center min-h-[calc(100vh-64px)] px-4 sm:px-6 py-6 relative overflow-hidden">

    <!-- 🌈 Background blobs (optimized for mobile) -->
    <div class="hidden sm:block absolute top-[-10%] right-[-5%] w-72 h-72 sm:w-96 sm:h-96 bg-primary/10 blur-[100px] sm:blur-[120px] rounded-full"></div>
    <div class="hidden sm:block absolute bottom-[-10%] left-[-5%] w-72 h-72 sm:w-96 sm:h-96 bg-indigo-200/30 blur-[100px] sm:blur-[120px] rounded-full"></div>

    <div class="w-full max-w-[480px] z-10">

        <!-- 💎 Card -->
        <div class="bg-white/70 backdrop-blur-[20px] rounded-[2rem]
                    p-6 sm:p-8 md:p-12
                    shadow-[0_32px_64px_rgba(17,48,105,0.08)]
                    ring-1 ring-white/50">

            <!-- Title -->
            <div class="text-center mb-8 sm:mb-10">
                <h1 class="text-2xl sm:text-3xl font-extrabold tracking-tight mb-2">
                    Set Your Context
                </h1>
                <p class="text-on-surface-variant font-medium text-sm sm:text-base">
                    Select distributor and reporting period
                </p>
            </div>

            <!-- Form -->
            <form method="get" asp-page="Index" class="space-y-5 sm:space-y-6">

                <!-- Distributor -->
                <div class="space-y-2">
                    <label class="text-[10px] sm:text-xs font-bold uppercase tracking-wider text-on-surface-variant pl-1">
                        Distributor
                    </label>

                    <select asp-for="SelectedClientId"
                            asp-items="Model.Tenants"
                            onchange="this.form.submit()"
                            class="w-full bg-surface-container-low border-none rounded-xl px-4 py-3 sm:py-4
                                   text-sm sm:text-base
                                   font-medium
                                   focus:ring-2 focus:ring-primary/20 outline-none cursor-pointer">

                        <option value="">-- Select a distributor --</option>
                    </select>
                </div>

                <!-- Week -->
                @if (Model.Weeks.Any())
                {
                    <div class="space-y-2">
                        <label class="text-[10px] sm:text-xs font-bold uppercase tracking-wider text-on-surface-variant pl-1">
                            Reporting Week
                        </label>

                        <select asp-for="SelectedPeriodEnd"
                                asp-items="Model.Weeks"
                                onchange="this.form.submit()"
                                class="w-full bg-surface-container-low border-none rounded-xl px-4 py-3 sm:py-4
                                           text-sm sm:text-base
                                           font-medium
                                           focus:ring-2 focus:ring-primary/20 outline-none cursor-pointer">

                            <option value="">-- Select a week --</option>
                        </select>
                    </div>
                }
                else if (!string.IsNullOrEmpty(Model.SelectedClientId))
                {
                    <div class="text-sm text-error pt-2">
                        No weeks found for this distributor.
                    </div>
                }

                <!-- Button -->
                <div class="pt-3 sm:pt-4">
                    <button type="submit"
                            class="w-full bg-gradient-to-br from-primary to-primary-dim
                                   text-white font-bold py-3 sm:py-4 rounded-xl
                                   text-sm sm:text-base
                                   shadow-lg shadow-primary/20
                                   hover:-translate-y-0.5 active:scale-95
                                   transition-all flex items-center justify-center gap-2">

                        View Dashboard →
                    </button>
                </div>

            </form>

            <!-- Bottom -->
            <div class="mt-6 sm:mt-8 pt-6 sm:pt-8 border-t border-surface-container-high text-center">
                <p class="text-xs sm:text-sm text-on-surface-variant">
                    Need access to another distributor?
                    <a href="#" class="text-primary font-bold hover:underline ml-1">
                        Request Access
                    </a>
                </p>
            </div>

        </div>

        <!-- 📊 Info Cards -->
        <div class="mt-6 sm:mt-8 grid grid-cols-1 sm:grid-cols-2 gap-4">

            <div class="bg-surface-container-low p-4 rounded-xl flex items-center gap-3">
                <div class="bg-primary/10 p-2 rounded-lg">🔐</div>
                <div>
                    <p class="text-[10px] uppercase font-bold text-on-surface-variant">Secured</p>
                    <p class="text-xs font-semibold">AES-256</p>
                </div>
            </div>

            <div class="bg-surface-container-low p-4 rounded-xl flex items-center gap-3">
                <div class="bg-yellow-100 p-2 rounded-lg">🗄️</div>
                <div>
                    <p class="text-[10px] uppercase font-bold text-on-surface-variant">Data</p>
                    <p class="text-xs font-semibold">Distribution</p>
                </div>
            </div>

        </div>

    </div>

</div>