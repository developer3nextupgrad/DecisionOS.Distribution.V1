@page
@model LoginModel
@{
    ViewData["Title"] = "Sign in";
    Layout = "_AuthLayout";
}

<script src="https://cdn.tailwindcss.com"></script>

<div class="min-h-screen bg-[#f5f7fb] relative overflow-hidden font-sans pt-16 md:pt-20">

    <!-- Background blobs -->
    <div class="absolute top-[-10%] left-[-5%] w-[40%] h-[40%] bg-[#0b6b2e]/20 blur-[120px] rounded-full"></div>
    <div class="absolute bottom-[-10%] right-[-5%] w-[35%] h-[40%] bg-indigo-300/20 blur-[120px] rounded-full"></div>

    <div class="flex flex-col items-center">

        <!-- Logo -->
        <div class="text-center mb-6">
            <div class="w-14 h-14 bg-[#0b6b2e] rounded-xl flex items-center justify-center text-white text-xl shadow-md mx-auto">
                📊
            </div>

            <h2 class="mt-4 text-2xl font-bold text-[#1e3a8a]">
                Decision OS
            </h2>
        </div>

        <!-- Card -->
        <div class="w-full max-w-md bg-white rounded-2xl shadow-[0_10px_30px_rgba(0,0,0,0.05)] px-10 py-12">

            <h3 class="text-xl font-bold text-gray-800">Sign In</h3>
            <p class="text-sm text-gray-500 mb-6">
                Enter your credentials to access your dashboard.
            </p>

            <form method="post" class="space-y-5">

                <div asp-validation-summary="All" class="text-red-500 text-sm"></div>

                <!-- Email -->
                <div>
                    <label class="text-xs font-bold text-gray-500 tracking-wide">
                        EMAIL ADDRESS
                    </label>

                    <div class="relative mt-2">
                        <span class="absolute left-3 top-3 text-gray-400">📧</span>

                        <input asp-for="Email"
                               class="w-full pl-10 pr-4 py-3 rounded-xl bg-[#f1f5f9] border border-gray-200 focus:border-[#0b6b2e] focus:ring-2 focus:ring-[#0b6b2e]/20 outline-none text-sm"
                               placeholder="name@company.com" />
                    </div>
                </div>

                <!-- Password -->
                <div>
                    <div class="flex justify-between text-xs mb-2">
                        <label class="font-bold text-gray-500 tracking-wide">
                            PASSWORD
                        </label>
                        <a href="#" class="text-[#0b6b2e] hover:underline">
                            Forgot password?
                        </a>
                    </div>

                    <div class="relative">
                        <span class="absolute left-3 top-3 text-gray-400">🔒</span>

                        <input asp-for="Password"
                               type="password"
                               class="w-full pl-10 pr-10 py-3 rounded-xl bg-[#f1f5f9] border border-gray-200 focus:border-[#0b6b2e] focus:ring-2 focus:ring-[#0b6b2e]/20 outline-none text-sm" />

                        <span class="absolute right-3 top-3 text-gray-400 cursor-pointer">👁️</span>
                    </div>
                </div>

                <!-- Remember -->
                <div class="flex items-center gap-2 text-sm text-gray-600 mt-2">
                    <input type="checkbox" class="accent-[#0b6b2e] w-4 h-4">
                    <label>Remember this device</label>
                </div>

                <!-- Submit -->
                <button type="submit"
                        class="w-full py-3 mt-2 bg-[#0b6b2e] hover:bg-[#095424] text-white font-semibold rounded-xl shadow-md transition">
                    Sign In
                </button>

                <!-- Divider -->
                <div class="flex items-center gap-3 my-4">
                    <div class="flex-1 h-px bg-gray-200"></div>
                    <span class="text-[11px] text-gray-400 tracking-widest uppercase">
                        Or continue with
                    </span>
                    <div class="flex-1 h-px bg-gray-200"></div>
                </div>

                <!-- Social -->
                <div class="grid grid-cols-2 gap-3">
                    <button type="button"
                            class="bg-[#f1f5f9] hover:bg-gray-200 py-2.5 rounded-xl border border-gray-200">
                        Google
                    </button>

                    <button type="button"
                            class="bg-[#f1f5f9] hover:bg-gray-200 py-2.5 rounded-xl border border-gray-200">
                        SSO
                    </button>
                </div>

            </form>
        </div>

        <!-- Bottom text -->
        <p class="mt-6 text-sm text-gray-500">
            Don’t have an account?
            <a href="#" class="text-[#0b6b2e] font-semibold hover:underline">
                Contact Support
            </a>
        </p>
        <div class="fixed bottom-6 right-6 bg-indigo-100 text-gray-700 px-4 py-2 rounded-full text-sm shadow-md hover:shadow-lg transition cursor-pointer">
            ❓ Need help?
        </div>

    </div>
</div>