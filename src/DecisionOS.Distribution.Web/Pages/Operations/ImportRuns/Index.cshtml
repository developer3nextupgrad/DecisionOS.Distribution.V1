@page
@model IndexModel
@{
    ViewData["Title"] = "Import history";
}
<h1 class="page-title">Import history</h1>
<p class="text-muted text-sm">Audit trail for CLI imports (idempotency fingerprint per run).</p>
<div class="table-wrapper">
    <table class="data-table">
        <thead>
        <tr>
            <th>Started (UTC)</th>
            <th>Tenant</th>
            <th>Week</th>
            <th>Status</th>
            <th>KPI rows</th>
            <th>Driver rows</th>
            <th>Fingerprint</th>
        </tr>
        </thead>
        <tbody>
        @foreach (var r in Model.Items)
        {
            <tr>
                <td>@r.StartedAt.ToString("u")</td>
                <td><code>@r.ClientId</code><br /><span class="text-muted text-sm">@r.TenantName</span></td>
                <td>@r.PeriodEnd.ToString("yyyy-MM-dd")</td>
                <td>
                    <strong>@r.Status</strong>
                    @if (!string.IsNullOrEmpty(r.Error))
                    {
                        <div class="text-sm text-muted" style="max-width:240px;">@r.Error</div>
                    }
                    @if (!string.IsNullOrEmpty(r.ValidationSummary))
                    {
                        <pre class="text-sm" style="white-space:pre-wrap;max-width:320px;">@r.ValidationSummary</pre>
                    }
                </td>
                <td>@r.KpiRows</td>
                <td>@r.DriverRows</td>
                <td class="text-sm" style="max-width:120px;overflow:hidden;text-overflow:ellipsis;" title="@r.Fingerprint">
                    @(r.Fingerprint is { Length: > 0 } fp ? fp[..Math.Min(fp.Length, 16)] + "…" : "—")
                </td>
            </tr>
        }
        </tbody>
    </table>
</div>
<p class="text-sm"><a href="/">Dashboard</a> &middot; <a href="/Admin">Admin</a></p>
