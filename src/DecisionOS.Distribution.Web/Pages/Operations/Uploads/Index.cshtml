@page
@model DecisionOS.Distribution.Web.Pages.Operations.Uploads.IndexModel
@using DecisionOS.Distribution.Domain.Uploads
@{
    ViewData["Title"] = "Upload Batches";
    Layout = "_Layout";
}

<div class="max-w-[1200px] mx-auto space-y-8">
    <div class="flex items-end justify-between">
        <div>
            <h1 class="text-3xl font-headline font-bold">Upload Batches</h1>
            <p class="text-sm text-on-surface-variant mt-1">Structured manual uploads by report type (V1 linkup).</p>
        </div>

        <a href="/Operations/Uploads/Create"
           class="flex items-center gap-2 bg-gradient-to-br from-primary to-primary-dim text-white px-6 py-3 rounded-xl font-bold shadow hover:scale-[0.98] transition">
            <span class="material-symbols-outlined">add</span>
            New Batch
        </a>
    </div>

    <div class="bg-surface-container-lowest rounded-xl shadow overflow-hidden border border-surface-container-high">
        <div class="overflow-x-auto">
            <table class="w-full min-w-[900px] text-sm">
                <thead class="bg-surface-container-low text-on-surface-variant uppercase text-xs">
                <tr>
                    <th class="px-6 py-4 text-left">Created</th>
                    <th class="px-6 py-4 text-left">Tenant</th>
                    <th class="px-6 py-4 text-left">Week</th>
                    <th class="px-6 py-4 text-left">Mode</th>
                    <th class="px-6 py-4 text-left">Status</th>
                    <th class="px-6 py-4 text-left">Readiness</th>
                    <th class="px-6 py-4 text-right">Files</th>
                    <th class="px-6 py-4 text-right">Actions</th>
                </tr>
                </thead>
                <tbody class="divide-y">
                @foreach (var r in Model.Items)
                {
                    <tr class="hover:bg-surface-container-low transition">
                        <td class="px-6 py-4 text-xs font-mono text-on-surface-variant">@r.CreatedAt.ToString("u")</td>
                        <td class="px-6 py-4">
                            <div class="flex flex-col">
                                <span class="font-semibold">@r.TenantName</span>
                                <span class="text-[10px] text-on-surface-variant font-mono">@r.ClientId</span>
                            </div>
                        </td>
                        <td class="px-6 py-4 text-on-surface-variant">@r.PeriodEnd.ToString("yyyy-MM-dd")</td>
                        <td class="px-6 py-4 text-xs">@(r.ImportMode == UploadImportMode.Simplified ? "Simplified" : "Classic")</td>
                        <td class="px-6 py-4"><span class="px-3 py-1 rounded-full text-xs font-bold bg-primary/10 text-primary">@r.Status</span></td>
                        <td class="px-6 py-4 text-xs font-mono text-on-surface-variant">@(string.IsNullOrWhiteSpace(r.Readiness) ? "—" : r.Readiness)</td>
                        <td class="px-6 py-4 text-right font-semibold">@r.FileCount</td>
                        <td class="px-6 py-4 text-right">
                            @{
                                var openUrl = r.ImportMode == UploadImportMode.Simplified
                                    ? $"/Operations/Uploads/Simplified/Verify?id={r.Id}"
                                    : $"/Operations/Uploads/Details?id={r.Id}";
                            }
                            <a class="px-3 py-1 text-xs font-semibold text-primary border border-primary/20 rounded-lg hover:bg-primary/10"
                               href="@openUrl">Open</a>
                        </td>
                    </tr>
                }
                </tbody>
            </table>
        </div>
    </div>
</div>

