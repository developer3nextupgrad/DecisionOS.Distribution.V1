@page
@model DashboardModel
@{
    ViewData["Title"] = "Dashboard";
}

<style>
    /* ── Page Header ── */
    .page-header {
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 1rem;
        margin-bottom: 2rem;
        flex-wrap: wrap;
    }
    .page-title { margin: 0; font-size: 1.75rem; font-weight: 700; color: #0f172a; }
    .text-muted { color: #64748b; }
    .text-sm { font-size: 0.85rem; }

    /* ── Buttons ── */
    .btn { display: inline-flex; align-items: center; gap: 0.5rem; padding: 0.5rem 1rem; border-radius: 0.5rem; font-size: 0.875rem; font-weight: 500; text-decoration: none; cursor: pointer; transition: all 0.15s ease; }
    .btn-outline { background: transparent; border: 1px solid #cbd5e1; color: #334155; }
    .btn-outline:hover { background: #f1f5f9; border-color: #94a3b8; }

    /* ── Summary Tiles ── */
    .summary-tiles { display: flex; gap: 1rem; margin-bottom: 2rem; flex-wrap: wrap; }
    .summary-tile {
        display: flex; align-items: center; gap: 0.75rem;
        background: #fff; border: 1px solid #e2e8f0; border-radius: 0.75rem;
        padding: 1rem 1.5rem; flex: 1; min-width: 160px;
        box-shadow: 0 1px 2px rgba(0,0,0,.04);
    }
    .status-dot { width: 12px; height: 12px; border-radius: 50%; flex-shrink: 0; }
    .dot-green  { background: #22c55e; }
    .dot-yellow { background: #eab308; }
    .dot-red    { background: #ef4444; }
    .summary-count { font-size: 1.75rem; font-weight: 700; color: #0f172a; line-height: 1; }

    /* ── Alert Banner ── */
    .alert-banner {
        display: flex; align-items: center; gap: 1rem;
        background: #fff; border: 1px solid #e2e8f0; border-left: 4px solid #e2e8f0;
        border-radius: 0.75rem; padding: 1rem 1.25rem; margin-bottom: 2rem;
        box-shadow: 0 1px 3px rgba(0,0,0,.06);
    }
    .alert-banner.border-red    { border-left-color: #ef4444; background: #fef2f2; }
    .alert-banner.border-yellow { border-left-color: #eab308; background: #fefce8; }
    .alert-banner.border-green  { border-left-color: #22c55e; background: #f0fdf4; }
    .alert-icon { flex-shrink: 0; color: #94a3b8; }
    .alert-banner.border-red .alert-icon    { color: #ef4444; }
    .alert-banner.border-yellow .alert-icon { color: #eab308; }
    .alert-content { flex: 1; min-width: 0; }
    .alert-title { margin: 0 0 0.25rem; font-size: 1rem; font-weight: 600; color: #0f172a; }
    .alert-subtitle { margin: 0; font-size: 0.875rem; color: #475569; }

    /* ── Badges ── */
    .badge {
        display: inline-flex; align-items: center; padding: 0.2rem 0.65rem;
        border-radius: 9999px; font-size: 0.75rem; font-weight: 600;
        text-transform: uppercase; letter-spacing: 0.025em; white-space: nowrap;
    }
    .badge.status-green  { background: #dcfce7; color: #166534; }
    .badge.status-yellow { background: #fef9c3; color: #854d0e; }
    .badge.status-red    { background: #fee2e2; color: #991b1b; }

    /* ── KPI Grid ── */
    .kpi-grid {
        display: grid;
        grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
        gap: 1rem; margin-bottom: 2rem;
    }
    .kpi-tile {
        background: #fff; border: 1px solid #e2e8f0; border-left: 4px solid #e2e8f0;
        border-radius: 0.75rem; padding: 1.25rem;
        box-shadow: 0 1px 2px rgba(0,0,0,.04);
        transition: box-shadow 0.15s ease, transform 0.15s ease;
    }
    .kpi-tile:hover { box-shadow: 0 4px 12px rgba(0,0,0,.08); transform: translateY(-1px); }
    .kpi-tile.border-green  { border-left-color: #22c55e; }
    .kpi-tile.border-yellow { border-left-color: #eab308; }
    .kpi-tile.border-red    { border-left-color: #ef4444; }
    .kpi-tile-header { display: flex; align-items: center; justify-content: space-between; margin-bottom: 0.75rem; gap: 0.5rem; }
    .kpi-name { font-size: 0.875rem; font-weight: 600; color: #334155; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }
    .kpi-value { font-size: 2rem; font-weight: 700; color: #0f172a; line-height: 1.2; margin-bottom: 0.5rem; }
    .kpi-meta { display: flex; justify-content: space-between; align-items: center; gap: 0.5rem; }

    /* ── WoW indicators ── */
    .wow-positive { color: #16a34a; font-weight: 600; }
    .wow-negative { color: #dc2626; font-weight: 600; }

    /* ── Cards ── */
    .card {
        background: #fff; border: 1px solid #e2e8f0; border-radius: 0.75rem;
        box-shadow: 0 1px 3px rgba(0,0,0,.06); margin-bottom: 2rem; overflow: hidden;
    }
    .card-header {
        padding: 1.25rem 1.5rem; border-bottom: 1px solid #e2e8f0;
        background: #f8fafc;
    }
    .card-header h2 { margin: 0; font-size: 1.1rem; font-weight: 600; color: #0f172a; }
    .card-body { padding: 1.5rem; }

    /* ── Focus Card ── */
    .focus-card .card-header { background: linear-gradient(135deg, #eff6ff 0%, #f0fdf4 100%); }
    .focus-question { margin: 0 0 1.25rem; font-size: 1.15rem; font-weight: 600; color: #1e293b; line-height: 1.5; }
    .focus-action, .focus-why { margin-bottom: 1rem; }
    .focus-action strong, .focus-why strong { display: block; font-size: 0.8rem; text-transform: uppercase; letter-spacing: 0.05em; color: #64748b; margin-bottom: 0.35rem; }
    .focus-action p, .focus-why p { margin: 0; color: #334155; line-height: 1.6; }
    .focus-meta { display: flex; gap: 0.5rem; flex-wrap: wrap; margin-top: 1rem; }
    .focus-meta .badge { background: #f1f5f9; color: #475569; font-weight: 500; text-transform: none; }

    /* ── Data Table ── */
    .table-wrapper { overflow-x: auto; }
    .data-table { width: 100%; border-collapse: collapse; font-size: 0.875rem; }
    .data-table th {
        text-align: left; padding: 0.75rem 1rem; font-weight: 600; color: #475569;
        background: #f8fafc; border-bottom: 2px solid #e2e8f0;
        font-size: 0.75rem; text-transform: uppercase; letter-spacing: 0.05em;
        white-space: nowrap;
    }
    .data-table td { padding: 0.75rem 1rem; border-bottom: 1px solid #f1f5f9; color: #334155; vertical-align: top; }
    .data-table tbody tr:hover { background: #f8fafc; }
    .data-table .rank-cell { font-weight: 700; color: #0f172a; text-align: center; }
    .data-table .context-cell { max-width: 200px; font-size: 0.8rem; color: #64748b; }
    .data-table .matters-cell { max-width: 240px; font-size: 0.8rem; color: #64748b; line-height: 1.5; }

    /* ── Empty State ── */
    .empty-state {
        text-align: center; padding: 4rem 2rem;
        background: #fff; border: 1px dashed #cbd5e1; border-radius: 0.75rem;
    }
    .empty-state-icon { margin-bottom: 1rem; color: #94a3b8; }
    .empty-state h2 { margin: 0 0 0.5rem; font-size: 1.25rem; font-weight: 600; color: #334155; }
    .empty-state p { margin: 0 0 1.5rem; color: #64748b; }
</style>

@if (Model.Snapshots.Count == 0)
{
    <div class="empty-state">
        <div class="empty-state-icon">
            <svg width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                <path d="M3 3v18h18"/>
                <path d="M7 16l4-8 4 4 4-6"/>
            </svg>
        </div>
        <h2>No Data Available</h2>
        <p>There are no KPI snapshots for this period. Try selecting a different week.</p>
        <a href="/" class="btn btn-outline">Back to Selection</a>
    </div>
}
else
{
    <!-- A. Header Bar -->
    <div class="page-header">
        <div>
            <h1 class="page-title">@Model.Tenant!.Name</h1>
            <p class="text-muted text-sm">Week ending @Model.ParsedPeriodEnd.ToString("MMMM d, yyyy") &middot; Distribution Pilot V1</p>
        </div>
        <a href="/" class="btn btn-outline">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <polyline points="15 18 9 12 15 6"/>
            </svg>
            Change Period
        </a>
    </div>

    <!-- B. Summary Tiles -->
    <div class="summary-tiles">
        <div class="summary-tile">
            <span class="status-dot dot-green"></span>
            <span class="summary-count">@Model.GreenCount</span>
            <span class="text-muted text-sm">On Track</span>
        </div>
        <div class="summary-tile">
            <span class="status-dot dot-yellow"></span>
            <span class="summary-count">@Model.YellowCount</span>
            <span class="text-muted text-sm">Needs Attention</span>
        </div>
        <div class="summary-tile">
            <span class="status-dot dot-red"></span>
            <span class="summary-count">@Model.RedCount</span>
            <span class="text-muted text-sm">Critical</span>
        </div>
    </div>

    <!-- C. Top Alert Banner -->
    @if (Model.TopAlert is not null)
    {
        <div class="alert-banner @Model.BorderCssClass(Model.TopAlert.Severity)">
            <div class="alert-icon">
                <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <path d="M10.29 3.86L1.82 18a2 2 0 001.71 3h16.94a2 2 0 001.71-3L13.71 3.86a2 2 0 00-3.42 0z"/>
                    <line x1="12" y1="9" x2="12" y2="13"/>
                    <line x1="12" y1="17" x2="12.01" y2="17"/>
                </svg>
            </div>
            <div class="alert-content">
                <h3 class="alert-title">Top Alert: @Model.TopAlert.KpiDefinition.Name</h3>
                <p class="alert-subtitle">@Model.TopAlert.ReasonSummary</p>
            </div>
            <span class="badge @Model.StatusCssClass(Model.TopAlert.Severity)">@Model.TopAlert.Severity</span>
        </div>
    }

    <!-- D. KPI Grid -->
    <div class="kpi-grid">
        @foreach (var snapshot in Model.Snapshots)
        {
            <div class="kpi-tile @Model.BorderCssClass(snapshot.Status)">
                <div class="kpi-tile-header">
                    <span class="kpi-name">@snapshot.KpiDefinition.Name</span>
                    <span class="badge @Model.StatusCssClass(snapshot.Status)">@snapshot.Status</span>
                </div>
                <div class="kpi-value">@Model.FormatValue(snapshot)</div>
                <div class="kpi-meta">
                    <span class="text-muted text-sm">Target: @Model.FormatTarget(snapshot.KpiDefinition)</span>
                    <span class="@Model.WoWCssClass(snapshot) text-sm">WoW: @Model.FormatWoW(snapshot)</span>
                </div>
            </div>
        }
    </div>

    <!-- E. Weekly Focus Card -->
    @if (Model.Focus is not null)
    {
        <div class="card focus-card">
            <div class="card-header">
                <h2>
                    <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="vertical-align: text-bottom; margin-right: 0.4rem;">
                        <circle cx="12" cy="12" r="10"/>
                        <circle cx="12" cy="12" r="6"/>
                        <circle cx="12" cy="12" r="2"/>
                    </svg>
                    Weekly Focus &mdash; @Model.Focus.KpiDefinition.Name
                </h2>
            </div>
            <div class="card-body">
                <h3 class="focus-question">@Model.Focus.DecisionQuestion</h3>
                <div class="focus-action">
                    <strong>Recommended Action</strong>
                    <p>@Model.Focus.RecommendedAction</p>
                </div>
                <div class="focus-why">
                    <strong>Why Now</strong>
                    <p>@Model.Focus.WhyNow</p>
                </div>
                <div class="focus-meta">
                    <span class="badge">
                        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="margin-right: 0.3rem;">
                            <path d="M20 21v-2a4 4 0 00-4-4H8a4 4 0 00-4 4v2"/>
                            <circle cx="12" cy="7" r="4"/>
                        </svg>
                        Owner: @Model.Focus.Owner
                    </span>
                    <span class="badge">
                        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="margin-right: 0.3rem;">
                            <circle cx="12" cy="12" r="10"/>
                            <polyline points="12 6 12 12 16 14"/>
                        </svg>
                        Cadence: @Model.Focus.Cadence
                    </span>
                </div>
            </div>
        </div>
    }

    <!-- F. Driver Drilldown Table -->
    @if (Model.Drivers.Count > 0)
    {
        <div class="card">
            <div class="card-header">
                <h2>
                    <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="vertical-align: text-bottom; margin-right: 0.4rem;">
                        <line x1="18" y1="20" x2="18" y2="10"/>
                        <line x1="12" y1="20" x2="12" y2="4"/>
                        <line x1="6" y1="20" x2="6" y2="14"/>
                    </svg>
                    Driver Analysis@(Model.TopAlert is not null ? $" \u2014 {Model.TopAlert.KpiDefinition.Name}" : "")
                </h2>
            </div>
            <div class="table-wrapper">
                <table class="data-table">
                    <thead>
                        <tr>
                            <th>Rank</th>
                            <th>Driver</th>
                            <th>Dimension</th>
                            <th>Current</th>
                            <th>WoW</th>
                            <th>Context</th>
                            <th>Status</th>
                            <th>Why It Matters</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var driver in Model.Drivers)
                        {
                            <tr>
                                <td class="rank-cell">@driver.Rank</td>
                                <td style="font-weight:600;">@driver.DriverName</td>
                                <td>
                                    @(driver.Dimension1 ?? "\u2014")
                                    @if (!string.IsNullOrEmpty(driver.Dimension2))
                                    {
                                        <br/><span class="text-muted text-sm">@driver.Dimension2</span>
                                    }
                                </td>
                                <td>@driver.Current.ToString("F2")</td>
                                <td>
                                    @if (driver.WeekOverWeekDelta.HasValue)
                                    {
                                        var delta = driver.WeekOverWeekDelta.Value;
                                        var prefix = delta >= 0 ? "+" : "";
                                        <span class="@(delta >= 0 ? "wow-positive" : "wow-negative")">@prefix@delta.ToString("F1")</span>
                                    }
                                    else
                                    {
                                        <span class="text-muted">&mdash;</span>
                                    }
                                </td>
                                <td class="context-cell">@(driver.Context ?? "\u2014")</td>
                                <td><span class="badge @Model.StatusCssClass(driver.Status)">@driver.Status</span></td>
                                <td class="matters-cell">@driver.WhyItMatters</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    }
}
