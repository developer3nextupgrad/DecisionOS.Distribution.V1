@{
    var currentPage = Context.Request.Path.Value ?? "";
}

<!DOCTYPE html>
<html lang="en" class="light">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Decision OS</title>

    <!-- Tailwind -->
    <script src="https://cdn.tailwindcss.com?plugins=forms,container-queries"></script>

    <!-- THEME -->
    <script>
        tailwind.config = {
            darkMode: "class",
            theme: {
                extend: {
                    colors: {
                        "background": "#faf8ff",
                        "surface": "#faf8ff",
                        "surface-container-lowest": "#ffffff",
                        "surface-container-low": "#f2f3ff",
                        "surface-container-high": "#e2e7ff",
                        "surface-container-highest": "#d9e2ff",
                        "on-surface": "#113069",
                        "on-surface-variant": "#445d99",
                        "primary": "#006e2f",
                        "primary-dim": "#006028",
                        "error": "#9e422c",
                        "outline": "#6079b7"
                    },
                    fontFamily: {
                        headline: ["Manrope"],
                        body: ["Inter"],
                        mono: ["JetBrains Mono"]
                    }
                }
            }
        }
    </script>

    <!-- Fonts -->
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600&family=Manrope:wght@600;700;800&display=swap" rel="stylesheet" />
    <link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined" rel="stylesheet" />

    <style>
        body {
            font-family: 'Inter', sans-serif;
        }

        h1, h2, h3 {
            font-family: 'Manrope', sans-serif;
        }

        .material-symbols-outlined {
            font-variation-settings: 'FILL' 0, 'wght' 400;
        }
    </style>
</head>

<body class="bg-background text-on-surface flex flex-col min-h-screen">

    <!-- HEADER -->
    <header class="fixed top-0 left-0 right-0 z-50 bg-background/80 backdrop-blur-xl border-b border-surface-container-high">

        <div class="flex justify-between items-center px-8 h-16 max-w-[1440px] mx-auto">

            <a href="/" class="flex items-center gap-3">
                <div class="bg-primary text-white p-2 rounded-lg shadow-sm">📊</div>
                <span class="text-xl font-bold font-headline">Decision OS</span>
            </a>

            <nav class="hidden md:flex gap-6 items-center text-sm font-medium text-on-surface-variant">

                <a href="/" class="hover:text-primary transition">Dashboard</a>

                @if (User.Identity?.IsAuthenticated == true)
                {
                    @if (User.IsInRole(DecisionOS.Distribution.Domain.Security.AppRoles.Admin))
                    {
                        <a href="/Admin" class="hover:text-primary">Admin</a>
                    }

                    @if (User.IsInRole(DecisionOS.Distribution.Domain.Security.AppRoles.Admin)
                                    || User.IsInRole(DecisionOS.Distribution.Domain.Security.AppRoles.Operator)
                                    || User.IsInRole(DecisionOS.Distribution.Domain.Security.AppRoles.Developer))
                    {
                        <a href="/Operations/ImportRuns" class="hover:text-primary">Imports</a>
                        <a href="/Operations/Uploads" class="hover:text-primary">Uploads</a>
                    }
                }
            </nav>

            <div class="flex items-center gap-4">

                <a href="/Notifications" id="notificationsLink" class="relative material-symbols-outlined text-on-surface-variant cursor-pointer hover:text-primary" title="Notifications">
                    notifications
                    <span id="notificationsBadge" class="hidden absolute -top-1 -right-2 min-w-[18px] h-[18px] px-1 rounded-full bg-error text-white text-[10px] font-bold flex items-center justify-center">0</span>
                </a>

                @if (User.Identity?.IsAuthenticated == true)
                {
                    <div class="flex items-center gap-3 pl-4 border-l border-surface-container-high">

                        <div class="text-right">
                            <div class="text-xs font-bold">@User.Identity.Name</div>

                            <form method="post" asp-page="/Account/Logout">
                                <button type="submit" class="text-[10px] uppercase text-primary font-bold">
                                    Logout
                                </button>
                            </form>
                        </div>

                        <div class="h-10 w-10 rounded-full bg-surface-container-high flex items-center justify-center">
                            👤
                        </div>
                    </div>
                }
                else
                {
                    <a href="/Account/Login" class="hover:text-primary">
                        Sign in
                    </a>
                }

            </div>
        </div>
    </header>

    <!-- SIDEBAR -->
    <aside class="hidden lg:flex fixed left-0 top-16 w-64 h-[calc(100vh-4rem)]
                  bg-surface-container-highest border-r border-surface-container-high
                  flex-col px-4 py-6 overflow-y-auto z-40">

        <div class="mb-8 px-2">
            <h2 class="text-lg font-bold font-headline">Decision OS</h2>
            <p class="text-xs text-on-surface-variant tracking-wide">ADMIN</p>
        </div>

        @functions {
            string Active(string key, string current) =>
            current.Contains(key)
            ? "bg-surface-container-lowest shadow-sm font-semibold"
            : "text-on-surface-variant hover:bg-white";
        }

        <nav class="flex-1 space-y-1">

            <a href="/Admin/VerticalLibraries" class="flex items-center gap-3 px-4 py-3 rounded-xl @Active("VerticalLibraries", currentPage)">
                <span class="material-symbols-outlined">library_books</span>
                Vertical Libraries
            </a>

            <a href="/Admin/Profiles" class="flex items-center gap-3 px-4 py-3 rounded-xl @Active("Profiles", currentPage)">
                <span class="material-symbols-outlined">business_center</span>
                Business Profiles
            </a>

            <a href="/Admin/Tenants" class="flex items-center gap-3 px-4 py-3 rounded-xl @Active("Tenants", currentPage)">
                <span class="material-symbols-outlined">domain</span>
                Tenants
            </a>

            <a href="/Admin/KpiDefinitions" class="flex items-center gap-3 px-4 py-3 rounded-xl @Active("KpiDefinitions", currentPage)">
                <span class="material-symbols-outlined">leaderboard</span>
                KPI Definitions
            </a>

            <a href="/Admin/DriverDefinitions" class="flex items-center gap-3 px-4 py-3 rounded-xl @Active("DriverDefinitions", currentPage)">
                <span class="material-symbols-outlined">account_tree</span>
                Driver Catalog
            </a>

            <a href="/Admin/Influencers" class="flex items-center gap-3 px-4 py-3 rounded-xl @Active("Influencers", currentPage)">
                <span class="material-symbols-outlined">insights</span>
                Influencers
            </a>

            <a href="/Admin/Users" class="flex items-center gap-3 px-4 py-3 rounded-xl @Active("Users", currentPage)">
                <span class="material-symbols-outlined">group</span>
                Users & Roles
            </a>

            <div class="my-4 border-t border-surface-container-high"></div>

            <a href="/Operations/ImportRuns" class="flex items-center gap-3 px-4 py-3 rounded-xl @Active("ImportRuns", currentPage)">
                <span class="material-symbols-outlined">history</span>
                Import History
            </a>

            <a href="/Operations/Uploads" class="flex items-center gap-3 px-4 py-3 rounded-xl @Active("Uploads", currentPage)">
                <span class="material-symbols-outlined">upload_file</span>
                Uploads
            </a>

            <a href="/Admin/ExcelMapper" class="flex items-center gap-3 px-4 py-3 rounded-xl @Active("ExcelMapper", currentPage)">
                <span class="material-symbols-outlined">table_edit</span>
                Excel Mapper
            </a>

        </nav>

    </aside>

    <!-- MAIN CONTENT -->
    <main class="flex-1 pt-16 lg:ml-64 p-6 overflow-y-auto">
        @RenderBody()
    </main>

    <!-- FOOTER -->
    <footer class="w-full py-6 text-center text-xs text-on-surface-variant uppercase tracking-widest">
        © @DateTime.UtcNow.Year Decision OS • All Rights Reserved
    </footer>

    @if (User.Identity?.IsAuthenticated == true)
    {
        <script>
            (async function () {
                try {
                    const res = await fetch("/api/notifications/unread-count", { credentials: "same-origin" });
                    if (!res.ok) return;
                    const data = await res.json();
                    const badge = document.getElementById("notificationsBadge");
                    if (!badge || !data.count) return;
                    badge.textContent = data.count > 9 ? "9+" : String(data.count);
                    badge.classList.remove("hidden");
                } catch { /* ignore */ }
            })();
        </script>
    }

</body>
</html>