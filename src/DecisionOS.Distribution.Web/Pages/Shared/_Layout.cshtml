<!DOCTYPE html>
<html lang="en" class="light">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Decision OS</title>

    <!-- Tailwind -->
    <script src="https://cdn.tailwindcss.com?plugins=forms"></script>

    <!-- Fonts -->
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600&family=Manrope:wght@600;700;800&display=swap" rel="stylesheet" />

    <script>
        tailwind.config = {
            theme: {
                extend: {
                    colors: {
                        primary: "#006e2f",
                        primaryDim: "#006028",
                        surface: "#faf8ff",
                        surfaceHigh: "#e2e7ff",
                        textMain: "#113069",
                        textMuted: "#445d99"
                    }
                }
            }
        }
    </script>

    <style>
        body {
            font-family: 'Inter', sans-serif;
        }

        h1, h2, h3 {
            font-family: 'Manrope', sans-serif;
        }
    </style>
</head>

<body class="bg-surface text-textMain min-h-screen flex flex-col">

    <!-- 🔥 MODERN NAVBAR (UPDATED WITH ICONS) -->
    <header class="sticky top-0 w-full z-50 bg-[#faf8ff]/80 backdrop-blur-xl shadow-[0_12px_32px_rgba(17,48,105,0.06)]">

        <div class="flex justify-between items-center w-full px-8 py-4 max-w-screen-2xl mx-auto">

            <!-- Logo -->
            <a href="/" class="flex items-center gap-3">
                <div class="bg-[#0b6b2e] p-2 rounded-lg flex items-center justify-center text-white text-lg shadow-sm">
                    📊
                </div>
                <span class="font-[Manrope] text-xl font-bold tracking-tight text-[#113069]">
                    Decision OS
                </span>
            </a>

            <!-- Nav Links -->
            <nav class="hidden md:flex items-center gap-8 text-sm font-medium font-[Manrope] text-[#445d99]">

                <a href="/" class="hover:text-[#113069] transition">Dashboard</a>

                @if (User.Identity?.IsAuthenticated == true)
                {
                    @if (User.IsInRole(DecisionOS.Distribution.Domain.Security.AppRoles.Admin))
                    {
                        <a href="/Admin" class="hover:text-[#113069]">Admin</a>
                    }

                    @if (User.IsInRole(DecisionOS.Distribution.Domain.Security.AppRoles.Admin)
                                    || User.IsInRole(DecisionOS.Distribution.Domain.Security.AppRoles.Operator)
                                    || User.IsInRole(DecisionOS.Distribution.Domain.Security.AppRoles.Developer))
                    {
                        <a href="/Operations/ImportRuns" class="hover:text-[#113069]">Imports</a>
                    }
                }
            </nav>

            <!-- Right Side -->
            <div class="flex items-center gap-6">

                <!-- Notification Icon -->
                <button class="text-on-surface-variant hover:bg-slate-100/50 p-2 rounded-full transition-all active:scale-95 duration-200">
                    <span class="material-symbols-outlined">
                        notifications
                    </span>
                </button>

                @if (User.Identity?.IsAuthenticated == true)
                {
                    <!-- User Info -->
                    <div class="flex items-center gap-3 pl-4 border-l border-[#d9e2ff]">

                        <div class="text-right">
                            <div class="text-xs font-bold text-[#113069] leading-none">
                                @User.Identity.Name
                            </div>

                            <form method="post" asp-page="/Account/Logout">
                                <button type="submit" class="text-[10px] uppercase tracking-widest font-bold text-[#0b6b2e] hover:text-[#095424]">
                                    Logout
                                </button>
                            </form>
                        </div>

                        <!-- 🔥 REPLACED IMAGE WITH ICON -->
                        <div class="h-10 w-10 rounded-full bg-[#e2e7ff] flex items-center justify-center border-2 border-white text-lg">
                            
                        </div>
                    </div>
                }
                else
                {
                    <a href="/Account/Login" class="text-[#445d99] hover:text-[#113069]">
                        Sign in
                    </a>
                }

            </div>
        </div>
    </header>

    <!-- 🔥 MAIN -->
    <main class="flex-1 w-full">
        @RenderBody()
    </main>

    <!-- 🔥 EXACT FOOTER -->
    <footer class="w-full py-8 text-center text-[10px] font-medium tracking-[0.2em] uppercase text-[#445d99]/60">
        © @DateTime.UtcNow.Year Decision OS Intelligent Canvas • All Rights Reserved
    </footer>

</body>
</html>